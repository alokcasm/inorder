    <script src="https://unpkg.com/@studio-freight/lenis@1.0.42/dist/lenis.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>
    
    <script>
        // Smooth scroll implementation
        const lenis = new Lenis({
            duration: 1.2,
            easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
            smooth: true,
            smoothTouch: false,
        });

        function raf(time) {
            lenis.raf(time);
            requestAnimationFrame(raf);
        }
        requestAnimationFrame(raf);

        // Connect Lenis with GSAP ScrollTrigger
        lenis.on('scroll', ScrollTrigger.update);
        gsap.ticker.add((time) => { lenis.raf(time * 1000) });
        gsap.ticker.lagSmoothing(0);


        // 1. Stack Animation via GSAP (Features Section)
        gsap.registerPlugin(ScrollTrigger);
        const featureCards = gsap.utils.toArray('.feature-card');
        
        featureCards.forEach((card, index) => {
            // We don't shrink the very last card
            if (index !== featureCards.length - 1) {
                gsap.to(card, {
                    scale: 0.9,
                    opacity: 0.4,
                    y: -10, // Gives a slight overlapping slide push back
                    scrollTrigger: {
                        trigger: featureCards[index + 1],
                        start: "top 75%", // When the next card comes up
                        end: "top 20%",   // When the next card fully overlaps it
                        scrub: true,
                    }
                });
            }
        });


        // 2. Pricing Slider Animation via GSAP
        const btnMonthly = document.getElementById('btn-monthly');
        const btnEnterprise = document.getElementById('btn-enterprise');
        const sliderIndicator = document.getElementById('slider-indicator');
        const pricingTrack = document.getElementById('pricing-track');

        btnMonthly.addEventListener('click', () => {
            // Update classes for color shift
            btnMonthly.classList.replace('text-gray-400', 'text-white');
            btnEnterprise.classList.replace('text-white', 'text-gray-400');
            
            // Move Indicator visually over the button
            gsap.to(sliderIndicator, { x: "0%", duration: 0.5, ease: "power3.out" });
            
            // Slide the entire pricing track horizontally
            gsap.to(pricingTrack, { x: "0%", duration: 0.6, ease: "power3.inOut" });
            
            // Subtle fade-in of the new visible card
            gsap.fromTo(pricingTrack.children[0], { opacity: 0.6 }, { opacity: 1, duration: 0.5, delay: 0.2 });
        });

        btnEnterprise.addEventListener('click', () => {
            // Update classes for color shift
            btnEnterprise.classList.replace('text-gray-400', 'text-white');
            btnMonthly.classList.replace('text-white', 'text-gray-400');
            
            // Move Indicator visually over the button
            gsap.to(sliderIndicator, { x: "100%", duration: 0.5, ease: "power3.out" });
            
            // Slide the entire pricing track horizontally (-50% on a 200% width container perfectly aligns the second half)
            gsap.to(pricingTrack, { x: "-50%", duration: 0.6, ease: "power3.inOut" });
            
            // Subtle fade-in of the new visible card
            gsap.fromTo(pricingTrack.children[1], { opacity: 0.6 }, { opacity: 1, duration: 0.5, delay: 0.2 });
        });

    </script>
