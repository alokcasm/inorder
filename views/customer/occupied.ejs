<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Table Occupied - <%= shopName %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <style>
        body { 
            font-family: 'Plus Jakarta Sans', sans-serif; 
            background-color: #07090F; 
            color: #ffffff; 
            -webkit-tap-highlight-color: transparent;
        }
        
        /* Smooth fade in */
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
        .animate-fade-in { animation: fadeIn 0.4s ease forwards; opacity: 0; }
        
        /* Soft pulse for the icon background */
        @keyframes softPulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.5; } }
        .animate-soft-pulse { animation: softPulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite; }
    </style>
</head>
<body class="antialiased selection:bg-orange-500/30 flex items-center justify-center min-h-screen p-4">

    <div class="max-w-sm w-full animate-fade-in" style="animation-delay: 0.1s;">
        
        <div class="bg-[#11141E] border border-white/[0.04] rounded-3xl p-8 text-center shadow-lg relative overflow-hidden">
            <!-- Subtle gradient background effect -->
            <div class="absolute inset-0 bg-gradient-to-br from-[#FF6B00]/5 to-transparent pointer-events-none"></div>
            
            <!-- Icon Container -->
            <div class="relative w-20 h-20 mx-auto mb-6">
                <!-- Pulsing outer ring -->
                <div class="absolute inset-0 bg-orange-500/20 rounded-full animate-soft-pulse blur-md"></div>
                <!-- Inner solid icon circle -->
                <div class="relative w-full h-full bg-[#161A26] border border-orange-500/30 rounded-full flex items-center justify-center shadow-sm">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#FF6B00" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                        <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                    </svg>
                </div>
            </div>

            <!-- Typography -->
            <p class="text-[11px] font-extrabold text-[#FF6B00] uppercase tracking-widest mb-2 relative z-10">Status: Occupied</p>
            
            <h1 class="text-[24px] font-black tracking-tight text-white mb-3 relative z-10 leading-tight">
                Table <%= tableNumber %> is taken
            </h1>
            
            <p class="text-[13px] font-medium text-gray-400 leading-relaxed relative z-10">
                Someone is currently ordering or dining at this table at <span class="text-white font-bold"><%= shopName %></span>. Please ask the staff for a different table or wait until they finish.
            </p>

            <!-- Refresh/Check Again Button -->
            <button onclick="if(navigator.vibrate) navigator.vibrate(15); window.location.reload()" class="w-full mt-8 bg-[#161A26] hover:bg-white/5 active:scale-[0.98] border border-white/[0.04] text-white font-bold text-[13px] py-3.5 rounded-2xl transition-all shadow-sm flex items-center justify-center gap-2 relative z-10 uppercase tracking-wider">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"></polyline><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"></path></svg>
                Check Again
            </button>
        </div>
        
    </div>

</body>
</html>