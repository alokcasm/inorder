<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Menu - <%= vendor.shopName %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #07090F; color: #ffffff; }
        .bg-gradient-primary { background-image: linear-gradient(to right, #FF6B00, #FF3D3D); }
        /* Hide scrollbar for a native app feel */
        ::-webkit-scrollbar { display: none; }
    </style>
</head>
<body class="antialiased pb-32">

    <!-- Header -->
    <div class="bg-[#0B0E16] border-b border-white/5 px-5 pt-8 pb-4 sticky top-0 z-40">
        <p class="text-[10px] text-orange-500 font-bold uppercase tracking-widest mb-1">Ordering At</p>
        <div class="flex justify-between items-center">
            <h1 class="text-2xl font-bold"><%= vendor.shopName %></h1>
            <div class="bg-white/10 px-3 py-1.5 rounded-full border border-white/10 flex items-center gap-1.5">
                <div class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></div>
                <span class="text-xs font-semibold">Table <%= table.tableNumber %></span>
            </div>
        </div>
    </div>

    <!-- Menu Items -->
    <div class="px-5 py-6 space-y-4">
        <% if (items.length === 0) { %>
            <p class="text-gray-500 text-center py-10">Menu is currently empty.</p>
        <% } else { %>
            <% items.forEach(item => { %>
                
                <!-- Helper variable to determine the final price -->
                <% const currentPrice = item.offerPrice ? item.offerPrice : item.price; %>
                
                <div class="bg-[#121624] border border-white/[0.04] p-3 rounded-2xl flex items-center gap-4 shadow-lg">
                    <img src="<%= item.image %>" alt="<%= item.name %>" class="w-20 h-20 rounded-xl object-cover bg-[#0B0E16]">
                    <div class="flex-1">
                        <h3 class="text-white font-semibold leading-tight"><%= item.name %></h3>
                        <p class="text-xs text-gray-400 mt-0.5 mb-1.5"><%= item.category %></p>
                        
                        <!-- Display Strikethrough if Offer Price exists -->
                        <div>
                            <% if(item.offerPrice) { %>
                                <span class="text-gray-500 line-through text-[11px] mr-1">₹<%= item.price %></span>
                            <% } %>
                            <span class="text-orange-400 font-bold">₹<%= currentPrice %></span>
                        </div>
                    </div>
                    
                    <!-- Add to Cart Button -->
                    <button onclick="addToCart('<%= item._id %>', '<%= item.name %>', <%= currentPrice %>)" class="w-10 h-10 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-orange-500 text-xl font-medium hover:bg-orange-500/20 transition-colors active:scale-95 shrink-0">
                        +
                    </button>
                </div>
            <% }) %>
        <% } %>
    </div>

    <!-- Sticky Bottom Checkout Bar -->
    <% if (!vendor.isApproved) { %>
        <!-- KYC PENDING OR SUSPENDED -->
        <div class="fixed bottom-0 left-0 w-full bg-red-600 text-white text-center py-5 font-bold z-50 shadow-[0_-10px_30px_rgba(220,38,38,0.4)]">
            🚫 Restaurant is currently suspended / awaiting verification.
        </div>
    <% } else if (!vendor.isOpen) { %>
        <!-- RESTAURANT TURNED OFF SWITCH -->
        <div class="fixed bottom-0 left-0 w-full bg-yellow-500 text-black text-center py-5 font-bold z-50 shadow-[0_-10px_30px_rgba(234,179,8,0.3)]">
            ⚠️ The kitchen is currently closed or busy.
        </div>
    <% } else { %>
        <!-- ALL GOOD - SHOW PAYMENT BUTTON -->
        <div class="fixed bottom-0 left-0 w-full bg-gradient-to-t from-[#07090F] via-[#07090F] to-transparent pt-10 pb-6 px-5 z-50">
            <button id="checkoutBtn" onclick="initiateCheckout('<%= table._id %>')" class="hidden w-full bg-gradient-primary text-white font-bold py-4 rounded-2xl shadow-[0_10px_25px_rgba(255,107,0,0.3)] flex justify-between items-center px-6 transform active:scale-[0.98] transition-transform">
                <div class="flex flex-col text-left">
                    <span class="text-[10px] uppercase tracking-wider text-white/80">Total Amount</span>
                    <span class="text-xl" id="cartTotal">₹0</span>
                </div>
                <div class="flex items-center gap-2">
                    Pay & Order <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </div>
            </button>
        </div>
    <% } %>

    <!-- Razorpay & Cart Scripts -->
    <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
    <script>
        let total = 0;
        const checkoutBtn = document.getElementById('checkoutBtn');
        const cartTotalEl = document.getElementById('cartTotal');

        // Add to cart logic
        function addToCart(itemId, name, price) {
            fetch('/cart/add', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ itemId, name, price })
            }).then(res => res.json()).then(data => {
                if(data.success) {
                    // Recalculate total from server cart
                    total = data.cart.reduce((sum, item) => sum + (item.price * item.quantity), 0);
                    cartTotalEl.innerText = '₹' + total;
                    
                    if(checkoutBtn) checkoutBtn.classList.remove('hidden'); // Show button
                    if (navigator.vibrate) navigator.vibrate(50); // Haptic feedback
                }
            });
        }

        // Razorpay Payment Logic
        function initiateCheckout(tableId) {
            if (!checkoutBtn) return;
            
            checkoutBtn.innerText = "Processing..."; 
            checkoutBtn.disabled = true;

            fetch('/checkout', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ tableId })
            })
            .then(res => res.json())
            .then(data => {
                if (data.error) {
                    alert(data.error);
                    window.location.reload();
                    return;
                }

                // Configure Razorpay Modal
                var options = {
                    "key": data.key, 
                    "amount": data.amount, 
                    "currency": "INR",
                    "name": data.shopName,
                    "description": "Food Order Payment",
                    "order_id": data.razorpayOrderId, 
                    "handler": function (response) {
                        // Payment Success! Verify signature on backend
                        fetch('/verify-payment', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({
                                razorpay_payment_id: response.razorpay_payment_id,
                                razorpay_order_id: response.razorpay_order_id,
                                razorpay_signature: response.razorpay_signature,
                                dbOrderId: data.orderId
                            })
                        }).then(res => res.json()).then(verifyData => {
                            if(verifyData.success) {
                                window.location.href = verifyData.redirectUrl; // Redirect to Live Tracking!
                            } else {
                                alert("Payment verification failed!");
                                checkoutBtn.innerText = "Pay & Order";
                                checkoutBtn.disabled = false;
                            }
                        });
                    },
                    "theme": { "color": "#FF6B00" }
                };
                
                var rzp = new Razorpay(options);
                rzp.on('payment.failed', function (response){
                    alert("Payment Failed. Please try again.");
                    checkoutBtn.innerHTML = `
                        <div class="flex flex-col text-left">
                            <span class="text-[10px] uppercase tracking-wider text-white/80">Total Amount</span>
                            <span class="text-xl">₹${total}</span>
                        </div>
                        <div class="flex items-center gap-2">
                            Pay & Order <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                        </div>
                    `;
                    checkoutBtn.disabled = false;
                });
                rzp.open();
            })
            .catch(err => {
                alert("Something went wrong initializing payment");
                window.location.reload();
            });
        }
    </script>
</body>
</html>