<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Receipt - <%= order._id %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Use a monospace font to make it look like a physical receipt -->
    <link href="https://fonts.googleapis.com/css2?family=Courier+Prime:wght@400;700&display=swap" rel="stylesheet">
    <style>
        body { 
            font-family: 'Courier Prime', monospace; 
            background-color: #f3f4f6; 
            color: #000;
        }
        .receipt-container {
            max-w: 400px;
            margin: 20px auto;
            background: #fff;
            padding: 30px 20px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
        }
        .dashed-line { border-top: 2px dashed #000; margin: 15px 0; }
        
        /* When the user clicks print, hide everything else and remove shadows */
        @media print {
            body { background: #fff; margin: 0; padding: 0; }
            .receipt-container { box-shadow: none; margin: 0; width: 100%; max-w: 100%; padding: 10px; }
            #printBtn { display: none; }
        }
    </style>
</head>
<body>

    <div class="receipt-container">
        <!-- Header -->
        <div class="text-center mb-6">
            <h1 class="text-2xl font-bold uppercase"><%= vendor.shopName %></h1>
            <p class="text-sm mt-1">Table No: <%= order.tableNumber %></p>
            <p class="text-xs mt-1">Date: <%= new Date(order.createdAt).toLocaleString() %></p>
            <p class="text-xs">Order ID: #<%= order._id.toString().slice(-6).toUpperCase() %></p>
        </div>

        <div class="dashed-line"></div>

        <!-- Items -->
        <div class="w-full text-sm space-y-2">
            <div class="flex justify-between font-bold mb-2">
                <span>ITEM (QTY)</span>
                <span>AMOUNT</span>
            </div>
            <% order.items.forEach(item => { %>
                <div class="flex justify-between">
                    <span class="pr-4"><%= item.name %> (x<%= item.quantity %>)</span>
                    <span>₹<%= item.price * item.quantity %></span>
                </div>
            <% }) %>
        </div>

        <div class="dashed-line"></div>

        <!-- Totals -->
        <div class="text-right space-y-1">
            <p class="text-xl font-bold">TOTAL: ₹<%= order.totalAmount %></p>
            <p class="text-sm uppercase">PAID VIA: <%= order.paymentMethod %></p>
        </div>

        <div class="dashed-line"></div>

        <!-- Footer -->
        <div class="text-center mt-6">
            <p class="text-sm font-bold">Thank you for dining with us!</p>
            <p class="text-xs mt-2">Powered by QueueZero</p>
        </div>

        <!-- Print Button (Hidden during actual printing) -->
        <button id="printBtn" onclick="window.print()" class="w-full mt-8 bg-black text-white font-bold py-3 rounded uppercase tracking-widest hover:bg-gray-800 transition">
            Print / Save as PDF
        </button>
    </div>

    <!-- Automatically open the print dialog when page loads -->
    <script>
        window.onload = function() {
            setTimeout(() => {
                window.print();
            }, 500);
        }
    </script>
</body>
</html>