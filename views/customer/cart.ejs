<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Cart - <%= vendor.shopName %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        body { 
            font-family: 'Plus Jakarta Sans', sans-serif; 
            background-color: #07090F; 
            color: #ffffff; 
            -webkit-tap-highlight-color: transparent;
        }
        
        ::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
        
        .bg-gradient-primary { background-image: linear-gradient(135deg, #FF6B00, #FF3D3D); }
        
        /* Smooth fade in */
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
        .animate-fade-in { animation: fadeIn 0.4s ease forwards; }
    </style>
</head>
<body class="antialiased selection:bg-orange-500/30">

    <% 
        let subTotal = 0; 
        if (cart && cart.length > 0) {
            cart.forEach(item => { subTotal += (item.price * item.quantity); });
        }
    %>

    <!-- Minimal Sticky Header -->
    <header class="sticky top-0 z-40 bg-[#07090F]/90 backdrop-blur-xl px-4 py-4 flex items-center justify-between border-b border-white/[0.04] shadow-sm">
        <a href="/t/<%= table._id %>" onclick="if(navigator.vibrate) navigator.vibrate(10)" class="w-[38px] h-[38px] flex items-center justify-center text-white active:scale-90 transition-transform bg-[#11141E] border border-white/5 rounded-full shadow-sm">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
        </a>
        <h1 class="text-[17px] font-extrabold tracking-tight text-white">Your Cart</h1>
        <div class="w-[38px]"></div> <!-- Spacer for perfect centering -->
    </header>

    <main class="px-4 pt-5 pb-36" id="mainCartArea">
        <% if(cart.length === 0) { %>
            <!-- Premium Empty State -->
            <div class="flex flex-col items-center justify-center mt-20 text-center animate-fade-in">
                <div class="w-24 h-24 bg-[#11141E] border border-white/5 rounded-full flex items-center justify-center mb-5 shadow-sm">
                    <span class="text-4xl opacity-50">🛒</span>
                </div>
                <h2 class="text-[19px] font-extrabold text-white mb-1.5 tracking-tight">Cart is empty</h2>
                <p class="text-[13px] text-gray-400 font-medium mb-8">Looks like you haven't added any food yet.</p>
                <a href="/t/<%= table._id %>" onclick="if(navigator.vibrate) navigator.vibrate(20)" class="bg-gradient-primary text-white font-bold text-[14px] px-8 py-3.5 rounded-xl shadow-[0_8px_25px_rgba(255,107,0,0.3)] active:scale-95 transition-transform flex items-center gap-2 border border-orange-500/30">
                    Browse Menu
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </a>
            </div>
        <% } else { %>
            
            <!-- Food Items List -->
            <div class="mb-6 animate-fade-in" id="cartItemsList">
                <h3 class="text-[11px] font-extrabold text-gray-500 uppercase tracking-widest mb-3 px-1">Order Items</h3>
                
                <div class="flex flex-col gap-3">
                    <% cart.forEach((item) => { %>
                        <div id="cart-item-<%= item.itemId %>" class="bg-[#11141E] border border-white/[0.04] rounded-2xl p-4 flex justify-between items-center gap-3 shadow-sm">
                            <div class="flex-1 pr-2">
                                <h4 class="text-[15px] font-bold text-white leading-snug mb-0.5"><%= item.name %></h4>
                                <p class="text-[12px] font-medium text-gray-400">₹<%= item.price %> per item</p>
                            </div>
                            
                            <div class="flex flex-col items-end gap-2.5">
                                <div class="text-[15px] font-extrabold text-white" id="price-<%= item.itemId %>">₹<%= item.price * item.quantity %></div>
                                
                                <!-- Compact Qty Controls -->
                                <div class="bg-[#161A26] border border-white/[0.06] rounded-lg flex items-center h-[34px] w-[88px] shadow-inner">
                                    <button onclick="updateCartItem('<%= item.itemId %>', 'decrease')" class="w-[30px] h-full flex items-center justify-center text-[#FF6B00] active:scale-75 transition-transform text-lg pb-0.5">-</button>
                                    <span id="qty-<%= item.itemId %>" class="flex-1 text-center text-[13px] font-extrabold text-white"><%= item.quantity %></span>
                                    <button onclick="updateCartItem('<%= item.itemId %>', 'increase')" class="w-[30px] h-full flex items-center justify-center text-[#FF6B00] active:scale-75 transition-transform text-lg pb-0.5">+</button>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                </div>
            </div>

            <!-- Simple Coupon Box -->
            <div class="bg-[#11141E] border border-white/[0.04] rounded-2xl p-3.5 mb-6 animate-fade-in shadow-sm" style="animation-delay: 0.1s;">
                <div class="flex gap-2">
                    <div class="relative flex-1">
                        <div class="absolute inset-y-0 left-3 flex items-center pointer-events-none">
                            <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path></svg>
                        </div>
                        <input type="text" id="couponCode" class="w-full bg-[#161A26] border border-transparent rounded-xl pl-9 pr-3 py-3 text-[13px] text-white font-bold uppercase tracking-wide focus:outline-none focus:border-orange-500/40 focus:bg-white/5 transition-all placeholder-gray-500" placeholder="PROMO CODE">
                    </div>
                    <button onclick="applyCoupon()" class="bg-[#f8f9fa] text-[#FF6B00] font-extrabold text-[12px] px-5 rounded-xl uppercase tracking-wider active:scale-95 transition-transform shadow-sm">Apply</button>
                </div>
                <p id="couponMsg" class="text-[12px] mt-2.5 font-bold hidden px-1"></p>
            </div>

            <!-- Minimal Bill Details -->
            <div class="bg-[#11141E] border border-white/[0.04] rounded-2xl p-4 animate-fade-in shadow-sm" style="animation-delay: 0.2s;">
                <h3 class="text-[11px] font-extrabold text-gray-500 uppercase tracking-widest mb-4">Bill Details</h3>
                
                <div class="space-y-3.5 text-[13px]">
                    <div class="flex justify-between items-center text-gray-300 font-medium">
                        <span>Item Total</span>
                        <span id="subTotalVal" class="text-white font-bold">₹<%= subTotal %></span>
                    </div>
                    
                    <div class="flex justify-between items-center text-emerald-400 font-bold hidden" id="discountRow">
                        <span>Discount Applied</span>
                        <span id="discountVal">-₹0</span>
                    </div>

                    <!-- Dashed Divider -->
                    <div class="border-t border-dashed border-white/10 pt-3.5 mt-1.5 flex justify-between items-end">
                        <span class="text-[14px] font-bold text-white tracking-tight">To Pay</span>
                        <span id="grandTotal" class="text-[22px] font-black text-[#FF6B00] leading-none tracking-tight">₹<%= subTotal %></span>
                    </div>
                </div>
            </div>

            <!-- Bottom Fixed Payment Button (Floating App Style) -->
            <div class="fixed bottom-0 left-0 w-full bg-gradient-to-t from-[#07090F] via-[#07090F] to-transparent pt-12 pb-5 px-4 z-50 pointer-events-none">
                <button id="checkoutBtn" onclick="startPayment()" class="w-full bg-gradient-primary text-white font-bold text-[15px] py-4 rounded-2xl shadow-[0_8px_25px_rgba(255,107,0,0.3)] border border-orange-400/30 flex justify-center items-center gap-2 pointer-events-auto active:scale-[0.98] transition-all">
                    Proceed to Pay
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                </button>
            </div>
        <% } %>
    </main>

    <!-- SCRIPTS (Logic Untouched, added haptic feedback) -->
    <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
    <script>
        const tableId = '<%= table._id %>';
        const vendorId = '<%= vendor._id %>';
        let localCart = <%- JSON.stringify(cart || []) %>;
        let appliedCouponObj = null;

        function updateCartItem(itemId, action) {
            if (navigator.vibrate) navigator.vibrate(20);

            const itemIndex = localCart.findIndex(i => i.itemId === itemId);
            if(itemIndex > -1) {
                if(action === 'increase') localCart[itemIndex].quantity++;
                if(action === 'decrease') localCart[itemIndex].quantity--;
                
                if(localCart[itemIndex].quantity <= 0) {
                    localCart.splice(itemIndex, 1);
                    document.getElementById(`cart-item-${itemId}`).style.display = 'none';
                } else {
                    document.getElementById(`qty-${itemId}`).innerText = localCart[itemIndex].quantity;
                    document.getElementById(`price-${itemId}`).innerText = '₹' + (localCart[itemIndex].price * localCart[itemIndex].quantity);
                }
            }

            fetch('/cart/update', {
                method: 'POST', headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ itemId, action })
            });

            recalculateTotals();
        }

        function recalculateTotals() {
            let newSubTotal = 0;
            localCart.forEach(item => newSubTotal += (item.price * item.quantity));

            if(newSubTotal === 0) return window.location.href = `/t/${tableId}`;

            document.getElementById('subTotalVal').innerText = '₹' + newSubTotal;
            
            if(appliedCouponObj) {
                let discount = appliedCouponObj.discountType === 'FLAT' ? appliedCouponObj.discountValue : (newSubTotal * appliedCouponObj.discountValue) / 100;
                let newTotal = newSubTotal - discount;
                if(newTotal <= 0) newTotal = 1;

                document.getElementById('discountVal').innerText = "-₹" + discount;
                document.getElementById('grandTotal').innerText = "₹" + newTotal;
            } else {
                document.getElementById('grandTotal').innerText = "₹" + newSubTotal;
            }
        }

        function applyCoupon() {
            const codeInput = document.getElementById('couponCode');
            const code = codeInput.value.trim();
            const msg = document.getElementById('couponMsg');
            if(!code) return;

            if (navigator.vibrate) navigator.vibrate(15);

            fetch('/cart/apply-coupon', {
                method: 'POST', headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ code, vendorId })
            }).then(res => res.json()).then(data => {
                msg.classList.remove('hidden');
                if(!data.success) {
                    msg.innerText = data.message; 
                    msg.className = "text-[12px] mt-2.5 font-bold text-red-400 block px-1";
                    appliedCouponObj = null;
                    recalculateTotals();
                    if (navigator.vibrate) navigator.vibrate([20, 50, 20]); // Error vibration
                    return;
                }
                
                appliedCouponObj = data.coupon; 
                msg.innerText = "🎉 Code '"+ data.coupon.code +"' applied!"; 
                msg.className = "text-[12px] mt-2.5 font-bold text-emerald-400 block px-1";
                document.getElementById('discountRow').classList.remove('hidden');
                document.getElementById('discountRow').classList.add('flex');
                
                recalculateTotals(); 
                if (navigator.vibrate) navigator.vibrate(50); // Success vibration
            });
        }

        function startPayment() {
            if (navigator.vibrate) navigator.vibrate(30);
            const btn = document.getElementById('checkoutBtn');
            btn.innerHTML = "Processing... ⏳"; 
            btn.disabled = true;

            fetch('/checkout', {
                method: 'POST', headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ tableId })
            }).then(res => res.json()).then(data => {
                if(data.error) { alert(data.error); window.location.reload(); return; }

                var options = {
                    "key": data.key, "amount": data.amount, "currency": "INR", "name": data.shopName, "order_id": data.razorpayOrderId,
                    "prefill": { "name": data.prefill.name, "contact": data.prefill.contact },
                    "handler": function (response) {
                        btn.innerHTML = "Verifying Payment... ✅";
                        fetch('/verify-payment', {
                            method: 'POST', headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({
                                razorpay_payment_id: response.razorpay_payment_id,
                                razorpay_order_id: response.razorpay_order_id,
                                razorpay_signature: response.razorpay_signature,
                                dbOrderId: data.orderId
                            })
                        }).then(res => res.json()).then(verify => {
                            if(verify.success) {
                                if (navigator.vibrate) navigator.vibrate([100, 50, 100]); 
                                window.location.href = verify.redirectUrl;
                            }
                        });
                    },
                    "modal": {
                        "ondismiss": function() {
                            btn.innerHTML = `Proceed to Pay <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>`;
                            btn.disabled = false;
                        }
                    },
                    "theme": { "color": "#FF6B00" }
                };
                var rzp = new Razorpay(options);
                rzp.open();
            });
        }
    </script>
</body>
</html>