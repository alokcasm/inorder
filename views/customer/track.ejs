<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Track Order - inOrder</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #07090F; color: #ffffff; }
        .bg-gradient-primary { background-image: linear-gradient(to right, #FF6B00, #FF3D3D); }
    </style>
</head>
<body class="antialiased pb-10">

    <div class="px-6 pt-12 pb-6 text-center border-b border-white/5 bg-[#0B0E16] sticky top-0 z-40 shadow-lg">
        <p class="text-xs text-gray-500 uppercase tracking-widest font-bold mb-2">Order Tracking</p>
        <h1 class="text-3xl font-bold"><%= vendor.shopName %></h1>
        <div class="mt-4 flex justify-center">
            <div class="bg-white/10 px-4 py-2 rounded-full border border-white/10 text-sm font-semibold flex items-center gap-2">
                Table <%= order.tableNumber %>
            </div>
        </div>
    </div>

    <div class="max-w-md mx-auto px-6 py-8">
        
        <!-- LIVE STATUS BADGE -->
        <div class="bg-[#121624] border border-white/5 rounded-3xl p-8 text-center shadow-[0_10px_40px_rgba(0,0,0,0.5)] relative overflow-hidden mb-8">
            <div class="absolute inset-0 bg-gradient-to-br from-orange-500/10 to-transparent pointer-events-none"></div>
            
            <p class="text-sm text-gray-400 mb-2 relative z-10">Current Status</p>
            
            <!-- This text will update via Socket.io! -->
            <h2 id="liveStatus" class="text-3xl font-bold text-orange-500 relative z-10 animate-pulse">
                <%= order.orderStatus %>
            </h2>
            
            <p class="text-xs text-gray-500 mt-4 relative z-10">Order ID: #<%= order._id.toString().slice(-6) %></p>
        </div>

        <!-- Order Summary -->
        <h3 class="text-lg font-bold mb-4">Order Summary</h3>
        <div class="bg-[#121624] border border-white/5 rounded-2xl p-5 mb-6 space-y-4">
            <% order.items.forEach(item => { %>
                <div class="flex justify-between items-center border-b border-white/5 pb-3 last:border-0 last:pb-0">
                    <div>
                        <p class="font-semibold text-white text-sm"><%= item.name %></p>
                        <p class="text-xs text-gray-500 mt-0.5">Qty: <%= item.quantity %></p>
                    </div>
                    <p class="font-bold text-gray-300 text-sm">₹<%= item.price * item.quantity %></p>
                </div>
            <% }) %>
            
            <div class="pt-3 border-t border-white/10 flex justify-between items-center">
                <p class="text-sm text-gray-400">Total Paid (<%= order.paymentMethod %>)</p>
                <p class="text-xl font-bold text-orange-400">₹<%= order.totalAmount %></p>
            </div>
        </div>

        <% if (order.orderStatus === 'Pending') { %>
    <!-- DIGITAL RECEIPT & RATING -->
    <!-- DIGITAL RECEIPT & RATING -->
<div class="bg-gradient-primary rounded-2xl p-6 shadow-xl text-center text-white mt-8 animate-fade-in">
    
    <p class="text-sm text-white/80 mb-4">Payment verified via Razorpay (#<%= order._id.toString().slice(-6) %>)</p>

    <!-- NEW: Download Receipt Button -->
    <a href="/receipt/<%= order._id %>" target="_blank" class="inline-flex items-center gap-2 bg-white text-orange-600 font-bold py-2 px-6 rounded-full shadow-lg mb-6 hover:scale-105 transition-transform text-sm">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
        Download Receipt
    </a>
    <% } %>

    <% if (order.orderStatus === 'Served') { %>
        <div class="text-4xl mb-3">🎉</div>
    <h2 class="text-2xl font-bold mb-1">Enjoy your meal!</h2>
    <div class="bg-gradient-primary rounded-2xl p-6 shadow-xl text-center text-white mt-8 animate-fade-in">
    
    <p class="text-sm text-white/80 mb-4">Payment verified via Razorpay (#<%= order._id.toString().slice(-6) %>)</p>

    <!-- NEW: Download Receipt Button -->
    <a href="/receipt/<%= order._id %>" target="_blank" class="inline-flex items-center gap-2 bg-white text-orange-600 font-bold py-2 px-6 rounded-full shadow-lg mb-6 hover:scale-105 transition-transform text-sm">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
        Download Receipt
    </a>
        <% if (!order.rating) { %>
            <div class="bg-black/20 rounded-xl p-5 backdrop-blur-sm">
                <h3 class="font-semibold mb-3">How was the food?</h3>
                <form action="/order/rate" method="POST">
                    <input type="hidden" name="orderId" value="<%= order._id %>">
                    
                    <!-- Star Rating (Simple implementation) -->
                    <div class="flex justify-center gap-2 mb-4 text-3xl cursor-pointer">
                        <input type="radio" name="rating" value="1" required class="accent-orange-500 w-5 h-5">1⭐
                        <input type="radio" name="rating" value="3" class="accent-orange-500 w-5 h-5">3⭐
                        <input type="radio" name="rating" value="5" class="accent-orange-500 w-5 h-5">5⭐
                    </div>
                    
                    <textarea name="comment" rows="2" placeholder="Leave a comment (optional)..." class="w-full bg-[#07090F] border border-white/10 rounded-lg p-3 text-sm text-white focus:outline-none mb-3"></textarea>
                    
                    <button type="submit" class="w-full bg-white text-orange-600 font-bold py-2.5 rounded-lg shadow-md hover:scale-[1.02] transition-transform">
                        Submit Feedback
                    </button>
                </form>
            </div>
        <% } else { %>
            <div class="bg-black/20 rounded-xl p-5 backdrop-blur-sm mt-4">
                <h3 class="font-bold text-lg text-yellow-300">You rated: <%= order.rating %> ⭐</h3>
                <% if(order.comment) { %><p class="text-sm italic mt-2">"<%= order.comment %>"</p><% } %>
                <p class="text-xs text-white/60 mt-3">Thank you for your feedback!</p>
            </div>
        <% } %>
    </div>
<% } %>
        
        <!-- Refresh Button (Fallback) -->
        <button onclick="window.location.reload()" class="w-full bg-white/5 hover:bg-white/10 border border-white/10 text-white font-medium py-3.5 rounded-xl transition-colors mt-5">
            Refresh Status
        </button>
    </div>

    <!-- SOCKET.IO CLIENT SCRIPT -->
    <script src="/socket.io/socket.io.js"></script>
    <script>
        const socket = io();
        const orderId = '<%= order._id %>';
        const statusEl = document.getElementById('liveStatus');

        // Join the specific room for this order
        socket.emit('joinOrderRoom', orderId);

        // Listen for updates from the kitchen!
        socket.on('statusUpdated', (newStatus) => {
            statusEl.innerText = newStatus;
            
            // Visual feedback based on status
            if(newStatus === 'Preparing') {
                statusEl.className = "text-3xl font-bold text-yellow-400 relative z-10 animate-pulse";
            } else if (newStatus === 'Ready') {
                statusEl.className = "text-3xl font-bold text-emerald-400 relative z-10 animate-bounce";
                if (navigator.vibrate) navigator.vibrate([200, 100, 200]); // Vibrate phone when food is ready!
            }
        });
    </script>
</body>
</html>