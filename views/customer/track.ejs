<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Track Order - <%= vendor.shopName %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <style>
        body { 
            font-family: 'Plus Jakarta Sans', sans-serif; 
            background-color: #07090F; 
            color: #ffffff; 
            -webkit-tap-highlight-color: transparent;
        }
        ::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
        
        .bg-gradient-primary { background-image: linear-gradient(135deg, #FF6B00, #FF3D3D); }
        
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
        .animate-fade-in { animation: fadeIn 0.4s ease forwards; opacity: 0; }
    </style>
</head>
<body class="antialiased selection:bg-orange-500/30 pb-10">

    <!-- Minimal Sticky Header -->
    <header class="sticky top-0 z-40 bg-[#07090F]/90 backdrop-blur-xl px-4 py-3.5 flex items-center justify-between border-b border-white/[0.04] shadow-sm">
        <div class="w-[38px]"></div> <!-- Left spacer for centering -->
        
        <div class="flex flex-col items-center justify-center">
            <h1 class="text-[17px] font-extrabold tracking-tight text-white"><%= vendor.shopName %></h1>
            <div class="bg-white/10 px-2.5 py-0.5 mt-0.5 rounded-full text-[10px] font-bold tracking-wider uppercase text-gray-300 flex items-center gap-1.5">
                <div class="w-1.5 h-1.5 bg-emerald-400 rounded-full animate-pulse shadow-[0_0_5px_rgba(52,211,153,0.8)]"></div>
                Table <%= order.tableNumber %>
            </div>
        </div>
        
        <div class="w-[38px]"></div> <!-- Right spacer for centering -->
    </header>

    <main class="px-4 pt-6 max-w-md mx-auto">
        
        <!-- LIVE STATUS BADGE -->
        <div class="bg-[#11141E] border border-white/[0.04] rounded-3xl p-8 text-center shadow-[0_10px_30px_rgba(0,0,0,0.5)] relative overflow-hidden mb-6 animate-fade-in" style="animation-delay: 0s;">
            <div class="absolute inset-0 bg-gradient-to-br from-[#FF6B00]/5 to-transparent pointer-events-none"></div>
            
            <p class="text-[11px] font-extrabold text-gray-500 uppercase tracking-widest mb-2 relative z-10">Current Status</p>
            
            <h2 id="liveStatus" class="text-[32px] font-black text-[#FF6B00] leading-none tracking-tight relative z-10 animate-pulse pb-1 drop-shadow-md">
                <%= order.orderStatus %>
            </h2>
            
            <p class="text-[11px] font-medium text-gray-400 mt-4 relative z-10">Latest Order ID: #<%= order._id.toString().slice(-6).toUpperCase() %></p>
        </div>

        <!-- SERVER-SIDE TIME CALCULATION -->
        <% 
            const serverNow = new Date().getTime();
            const orderTime = new Date(firstOrderTime).getTime(); 
            let remainingSeconds = Math.floor((120000 - (serverNow - orderTime)) / 1000);
            if (remainingSeconds < 0) remainingSeconds = 0;
            const isTimerExpired = remainingSeconds === 0;
        %>

        <!-- ⏱️ 2-MINUTE GRACE PERIOD & ACTIONS -->
        <% if (order.orderStatus === 'Pending' || order.orderStatus === 'Preparing') { %>
            <div class="animate-fade-in" style="animation-delay: 0.1s;">
                <!-- Timer Card -->
                <div class="bg-[#11141E] border border-white/[0.04] rounded-2xl p-4 mb-4 shadow-sm flex items-center justify-between">
                    <div>
                        <h4 class="font-bold text-white text-[14px] leading-tight mb-0.5">Need to change something?</h4>
                        <p class="text-[10px] text-gray-400 font-bold uppercase tracking-wider">Grace period remaining</p>
                    </div>
                    <div class="text-right">
                        <span id="timerDisplay" class="font-mono text-lg font-black <%= isTimerExpired ? 'text-red-500 bg-red-500/10 border-red-500/20' : 'text-[#FF6B00] bg-[#FF6B00]/10 border-[#FF6B00]/20' %> px-3 py-1.5 rounded-xl border transition-colors shadow-inner">
                            <%= isTimerExpired ? '00:00' : '02:00' %>
                        </span>
                    </div>
                </div>

                <!-- Action Buttons Container (FIXED: Included IDs and Receipt Button) -->
                <div class="flex gap-3 mb-6 w-full" id="actionButtonsContainer">
                    
                    <!-- EDIT BUTTON (Hides if timer expired) -->
                    <button id="editOrderBtn" onclick="handleEditClick()" class="<%= isTimerExpired ? 'hidden' : 'flex' %> flex-1 bg-[#11141E] hover:bg-white/5 text-white text-[12px] font-bold py-3.5 rounded-xl border border-white/[0.05] transition-all shadow-sm active:scale-95 items-center justify-center gap-2">
                        <span class="text-base">✏️</span> Edit Items
                    </button>
                    
                    <!-- ORDER MORE BUTTON (Hides if timer expired) -->
                    <a id="orderMoreBtn" href="/t/<%= tableId %>?addMore=true" class="<%= isTimerExpired ? 'hidden' : 'flex' %> flex-1 bg-gradient-primary text-white text-center text-[12px] font-bold py-3.5 rounded-xl shadow-[0_8px_20px_rgba(255,107,0,0.3)] transition-transform active:scale-95 items-center justify-center gap-2">
                        <span class="text-base">➕</span> Order More
                    </a>

                    <!-- RECEIPT BUTTON (Shows ONLY if timer expired. Takes full width) -->
                    <a id="earlyReceiptBtn" href="/receipt/<%= order._id %>" target="_blank" onclick="if(navigator.vibrate) navigator.vibrate(15)" class="<%= isTimerExpired ? 'flex' : 'hidden' %> w-full bg-white text-[#FF6B00] text-[12px] font-extrabold py-3.5 rounded-xl border border-white/[0.05] transition-all shadow-sm active:scale-95 items-center justify-center gap-2 uppercase tracking-wide">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
                        Download Receipt
                    </a>

                </div>
            </div>
        <% } %>

        <!-- Order Summary (COMBINED BILL) -->
        <div class="mb-6 animate-fade-in" style="animation-delay: 0.2s;">
            <h3 class="text-[11px] font-extrabold text-gray-500 uppercase tracking-widest mb-3 px-1">Complete Order Summary</h3>
            <div class="bg-[#11141E] border border-white/[0.04] rounded-2xl p-4 shadow-sm flex flex-col gap-3">
                
                <% combinedItems.forEach(item => { %>
                    <div class="flex justify-between items-center pb-3 border-b border-white/[0.04] last:border-0 last:pb-0">
                        <div>
                            <h4 class="text-[14px] font-bold text-white leading-snug mb-0.5"><%= item.name %></h4>
                            <p class="text-[12px] font-medium text-gray-400">Qty: <%= item.quantity %></p>
                        </div>
                        <p class="text-[14px] font-extrabold text-white">₹<%= item.price * item.quantity %></p>
                    </div>
                <% }) %>
                
                <div class="border-t border-dashed border-white/10 pt-3.5 mt-1 text-[13px] space-y-2.5">
                    <div class="flex justify-between items-center text-gray-300 font-medium">
                        <span>Subtotal</span>
                        <span class="text-white font-bold">₹<%= combinedSubTotal %></span>
                    </div>
                    
                    <% if (combinedDiscount > 0) { %>
                        <div class="flex justify-between items-center text-emerald-400 font-bold">
                            <span>Promo Discount</span>
                            <span>-₹<%= combinedDiscount %></span>
                        </div>
                    <% } %>

                    <div class="border-t border-white/[0.04] pt-3 mt-1.5 flex justify-between items-end">
                        <span class="text-[13px] font-bold text-white tracking-tight">Total Paid (All Orders)</span>
                        <span class="text-[20px] font-black text-[#FF6B00] leading-none tracking-tight">₹<%= combinedFinal %></span>
                    </div>
                </div>
            </div>
        </div>

        <!-- DIGITAL RECEIPT & RATING (Shows only when ALL orders are served) -->
        <% if (isAllServed) { %>
            <div class="text-center mb-6 animate-fade-in" style="animation-delay: 0.3s;">
                <div class="text-[40px] mb-2 inline-block animate-bounce" style="animation-duration: 2s;">🎉</div>
                <h2 class="text-[22px] font-black tracking-tight mb-5">Enjoy your meal!</h2>
                
                <div class="bg-gradient-primary rounded-[2rem] p-6 shadow-[0_15px_30px_rgba(255,107,0,0.3)] text-center text-white border border-orange-400/30">

                    <!-- Full Receipt Button (When Served) -->
                    <a href="/receipt/<%= order._id %>" target="_blank" onclick="if(navigator.vibrate) navigator.vibrate(15)" class="inline-flex items-center justify-center gap-2 bg-white text-[#FF6B00] font-extrabold text-[13px] py-3.5 px-6 rounded-xl shadow-md active:scale-95 transition-transform uppercase tracking-wider mb-6 w-full">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
                        Download Receipt
                    </a>

                    <% if (!order.rating) { %>
                        <div class="bg-black/20 rounded-2xl p-5 backdrop-blur-md border border-white/10 shadow-inner">
                            <h3 class="font-extrabold text-[14px] mb-4 tracking-wide">How was the food?</h3>
                            <form action="/order/rate" method="POST">
                                <input type="hidden" name="orderId" value="<%= order._id %>">
                                
                                <div class="flex justify-center gap-6 mb-5">
                                    <label class="flex flex-col items-center gap-1.5 cursor-pointer active:scale-90 transition-transform">
                                        <span class="text-[28px]">😡</span>
                                        <div class="flex items-center gap-1 text-[12px] font-bold"><input type="radio" name="rating" value="1" required class="accent-[#FF6B00] w-4 h-4"> 1</div>
                                    </label>
                                    <label class="flex flex-col items-center gap-1.5 cursor-pointer active:scale-90 transition-transform">
                                        <span class="text-[28px]">😐</span>
                                        <div class="flex items-center gap-1 text-[12px] font-bold"><input type="radio" name="rating" value="3" class="accent-[#FF6B00] w-4 h-4"> 3</div>
                                    </label>
                                    <label class="flex flex-col items-center gap-1.5 cursor-pointer active:scale-90 transition-transform">
                                        <span class="text-[28px]">😍</span>
                                        <div class="flex items-center gap-1 text-[12px] font-bold"><input type="radio" name="rating" value="5" class="accent-[#FF6B00] w-4 h-4"> 5</div>
                                    </label>
                                </div>
                                
                                <textarea name="comment" rows="2" placeholder="Leave a comment (optional)..." class="w-full bg-[#161A26] border border-transparent rounded-xl p-3 text-[13px] text-white focus:outline-none focus:border-white/30 transition-all mb-4 placeholder-white/40 shadow-inner resize-none"></textarea>
                                
                                <button type="submit" onclick="if(navigator.vibrate) navigator.vibrate(20)" class="w-full bg-white text-[#FF6B00] font-extrabold text-[14px] py-3.5 rounded-xl shadow-sm active:scale-95 transition-transform uppercase tracking-wider">
                                    Submit Feedback
                                </button>
                            </form>
                        </div>
                    <% } else { %>
                        <div class="bg-black/20 rounded-2xl p-5 backdrop-blur-md border border-white/10 mt-2 shadow-inner">
                            <h3 class="font-black text-[16px] text-[#FFD700]">You rated: <%= order.rating %> ⭐</h3>
                            <% if(order.comment) { %><p class="text-[13px] font-medium text-white/90 italic mt-2.5">"<%= order.comment %>"</p><% } %>
                            <p class="text-[11px] font-extrabold uppercase tracking-widest text-white/60 mt-4">Thank you for your feedback!</p>
                        </div>
                    <% } %>
                </div>
            </div>
        <% } %>
        
        <!-- Refresh Button -->
        <button onclick="if(navigator.vibrate) navigator.vibrate(15); window.location.reload()" class="mt-6 w-full bg-[#11141E] hover:bg-[#161A26] active:scale-[0.98] border border-white/[0.04] text-white font-bold text-[13px] py-3.5 rounded-xl transition-all shadow-sm flex items-center justify-center gap-2 animate-fade-in uppercase tracking-wider" style="animation-delay: 0.4s;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="23 4 23 10 17 10"></polyline><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"></path></svg>
            Refresh Status
        </button>
    </main>

    <!-- SOCKET.IO CLIENT SCRIPT -->
    <script src="/socket.io/socket.io.js"></script>
    <script>
        const socket = io();
        const orderId = '<%= order._id %>';
        const statusEl = document.getElementById('liveStatus');

        socket.emit('joinOrderRoom', orderId);

        socket.on('statusUpdated', (newStatus) => {
            statusEl.innerText = newStatus;
            
            if(newStatus === 'Preparing') {
                statusEl.className = "text-[32px] font-black text-yellow-400 leading-none tracking-tight relative z-10 animate-pulse pb-1 drop-shadow-md";
            } else if (newStatus === 'Ready') {
                statusEl.className = "text-[32px] font-black text-emerald-400 leading-none tracking-tight relative z-10 animate-bounce pb-1 drop-shadow-md";
                if (navigator.vibrate) navigator.vibrate([200, 100, 200]); 
            } else if (newStatus === 'Served') {
                window.location.reload(); 
            } else {
                statusEl.className = "text-[32px] font-black text-[#FF6B00] leading-none tracking-tight relative z-10 animate-pulse pb-1 drop-shadow-md";
            }
        });

        // --- BULLETPROOF TIMER LOGIC ---
        let remainingSeconds = <%= remainingSeconds %>;
        const timerDisplay = document.getElementById('timerDisplay');
        const editOrderBtn = document.getElementById('editOrderBtn');
        const orderMoreBtn = document.getElementById('orderMoreBtn');
        const earlyReceiptBtn = document.getElementById('earlyReceiptBtn');

        if (timerDisplay && remainingSeconds > 0) {
            const interval = setInterval(() => {
                remainingSeconds--;

                if (remainingSeconds <= 0) {
                    clearInterval(interval);
                    timerDisplay.innerText = "00:00";
                    timerDisplay.className = "font-mono text-lg font-black text-red-500 bg-red-500/10 px-3 py-1.5 rounded-xl border border-red-500/20 shadow-inner transition-colors";
                    
                    // The Magic UI Swap!
                    if(editOrderBtn) {
                        editOrderBtn.classList.add('hidden');
                        editOrderBtn.classList.remove('flex');
                    }
                    if(orderMoreBtn) {
                        orderMoreBtn.classList.add('hidden');
                        orderMoreBtn.classList.remove('flex');
                    }
                    if(earlyReceiptBtn) {
                        earlyReceiptBtn.classList.remove('hidden');
                        earlyReceiptBtn.classList.add('flex');
                    }
                } else {
                    const minutes = Math.floor(remainingSeconds / 60);
                    const seconds = remainingSeconds % 60;
                    timerDisplay.innerText = `0${minutes}:${seconds < 10 ? '0' : ''}${seconds}`;
                }
            }, 1000);
        }

        // Edit Warning Modal
        function handleEditClick() {
            alert("✅ You are within the 2-minute window!\n\nPlease quickly call the waiter or go to the counter to update your items, as your payment has already been processed.");
        }
    </script>
</body>
</html>