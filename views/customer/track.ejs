<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Track Order - <%= vendor.shopName %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <style>
        body { 
            font-family: 'Plus Jakarta Sans', sans-serif; 
            background-color: #07090F; 
            color: #ffffff; 
            -webkit-tap-highlight-color: transparent;
        }
        
        ::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
        
        .bg-gradient-primary { background-image: linear-gradient(135deg, #FF6B00, #FF3D3D); }
        
        /* Smooth fade in */
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
        .animate-fade-in { animation: fadeIn 0.4s ease forwards; opacity: 0; }
    </style>
</head>
<body class="antialiased selection:bg-orange-500/30 pb-10">

    <!-- Minimal Sticky Header -->
    <header class="sticky top-0 z-40 bg-[#07090F]/90 backdrop-blur-xl px-4 py-3.5 flex items-center justify-between border-b border-white/[0.04] shadow-sm">
        <button onclick="if(navigator.vibrate) navigator.vibrate(10); window.history.back()" class="w-[38px] h-[38px] flex items-center justify-center text-white active:scale-90 transition-transform bg-[#11141E] border border-white/5 rounded-full shadow-sm">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
        </button>
        
        <div class="flex flex-col items-center justify-center">
            <h1 class="text-[17px] font-extrabold tracking-tight text-white"><%= vendor.shopName %></h1>
            <div class="bg-white/10 px-2.5 py-0.5 mt-0.5 rounded-full text-[10px] font-bold tracking-wider uppercase text-gray-300">
                Table <%= order.tableNumber %>
            </div>
        </div>
        
        <div class="w-[38px]"></div> <!-- Spacer for perfect centering -->
    </header>

    <main class="px-4 pt-6 max-w-md mx-auto">
        
        <!-- LIVE STATUS BADGE -->
        <div class="bg-[#11141E] border border-white/[0.04] rounded-3xl p-8 text-center shadow-sm relative overflow-hidden mb-6 animate-fade-in" style="animation-delay: 0s;">
            <!-- Subtle glow behind the status -->
            <div class="absolute inset-0 bg-gradient-to-br from-[#FF6B00]/5 to-transparent pointer-events-none"></div>
            
            <p class="text-[11px] font-extrabold text-gray-500 uppercase tracking-widest mb-2 relative z-10">Current Status</p>
            
            <!-- Updates via Socket.io -->
            <h2 id="liveStatus" class="text-[32px] font-black text-[#FF6B00] leading-none tracking-tight relative z-10 animate-pulse pb-1">
                <%= order.orderStatus %>
            </h2>
            
            <p class="text-[12px] font-medium text-gray-400 mt-4 relative z-10">Order ID: #<%= order._id.toString().slice(-6) %></p>
        </div>

        <!-- Order Summary -->
        <div class="mb-6 animate-fade-in" style="animation-delay: 0.1s;">
            <h3 class="text-[11px] font-extrabold text-gray-500 uppercase tracking-widest mb-3 px-1">Order Summary</h3>
            <div class="bg-[#11141E] border border-white/[0.04] rounded-2xl p-4 shadow-sm flex flex-col gap-3">
                
                <!-- Item List -->
                <% order.items.forEach(item => { %>
                    <div class="flex justify-between items-center pb-3 border-b border-white/[0.04] last:border-0 last:pb-0">
                        <div>
                            <h4 class="text-[14px] font-bold text-white leading-snug mb-0.5"><%= item.name %></h4>
                            <p class="text-[12px] font-medium text-gray-400">Qty: <%= item.quantity %></p>
                        </div>
                        <p class="text-[14px] font-extrabold text-white">₹<%= item.price * item.quantity %></p>
                    </div>
                <% }) %>
                
                <!-- Bill Breakdown -->
                <div class="border-t border-dashed border-white/10 pt-3.5 mt-1 text-[13px] space-y-2.5">
                    <div class="flex justify-between items-center text-gray-300 font-medium">
                        <span>Subtotal</span>
                        <span class="text-white font-bold">₹<%= order.totalAmount %></span>
                    </div>
                    
                    <% if (order.discountApplied && order.discountApplied > 0) { %>
                        <div class="flex justify-between items-center text-emerald-400 font-bold">
                            <span>Discount Applied</span>
                            <span>-₹<%= order.discountApplied %></span>
                        </div>
                    <% } %>

                    <div class="border-t border-white/[0.04] pt-3 mt-1.5 flex justify-between items-end">
                        <span class="text-[13px] font-bold text-white tracking-tight">Total Paid (<%= order.paymentMethod %>)</span>
                        <span class="text-[20px] font-black text-[#FF6B00] leading-none tracking-tight">₹<%= order.finalAmount || order.totalAmount %></span>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- DYNAMIC SECTIONS BASED ON STATUS -->
        <% if (order.orderStatus === 'Pending') { %>
            <div class="bg-gradient-primary rounded-2xl p-6 shadow-[0_8px_25px_rgba(255,107,0,0.25)] text-center text-white mb-6 animate-fade-in border border-orange-400/30" style="animation-delay: 0.2s;">
                <p class="text-[13px] font-medium text-white/90 mb-4">Payment verified via Razorpay (#<%= order._id.toString().slice(-6) %>)</p>

                <a href="/receipt/<%= order._id %>" target="_blank" onclick="if(navigator.vibrate) navigator.vibrate(15)" class="inline-flex items-center justify-center gap-2 bg-white text-[#FF6B00] font-extrabold text-[13px] py-3 px-6 rounded-xl shadow-sm active:scale-95 transition-transform uppercase tracking-wider w-full">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
                    Download Receipt
                </a>
            </div>
        <% } %>

        <% if (order.orderStatus === 'Served') { %>
            <div class="text-center mb-6 animate-fade-in" style="animation-delay: 0.2s;">
                <div class="text-[40px] mb-2 inline-block animate-bounce" style="animation-duration: 2s;">🎉</div>
                <h2 class="text-[22px] font-black tracking-tight mb-5">Enjoy your meal!</h2>
                
                <div class="bg-gradient-primary rounded-2xl p-5 shadow-[0_8px_25px_rgba(255,107,0,0.25)] text-center text-white border border-orange-400/30">
                    <a href="/receipt/<%= order._id %>" target="_blank" onclick="if(navigator.vibrate) navigator.vibrate(15)" class="inline-flex items-center justify-center gap-2 bg-white text-[#FF6B00] font-extrabold text-[13px] py-2.5 px-6 rounded-xl shadow-sm active:scale-95 transition-transform uppercase tracking-wider mb-5">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
                        Download Receipt
                    </a>

                    <% if (!order.rating) { %>
                        <div class="bg-black/20 rounded-xl p-4 backdrop-blur-md border border-white/10">
                            <h3 class="font-extrabold text-[14px] mb-4 tracking-wide">How was the food?</h3>
                            <form action="/order/rate" method="POST">
                                <input type="hidden" name="orderId" value="<%= order._id %>">
                                
                                <!-- Premium Star Rating -->
                                <div class="flex justify-center gap-6 mb-5">
                                    <label class="flex flex-col items-center gap-1.5 cursor-pointer active:scale-90 transition-transform">
                                        <span class="text-[28px]">😡</span>
                                        <div class="flex items-center gap-1 text-[12px] font-bold"><input type="radio" name="rating" value="1" required class="accent-[#FF6B00] w-3.5 h-3.5"> 1</div>
                                    </label>
                                    <label class="flex flex-col items-center gap-1.5 cursor-pointer active:scale-90 transition-transform">
                                        <span class="text-[28px]">😐</span>
                                        <div class="flex items-center gap-1 text-[12px] font-bold"><input type="radio" name="rating" value="3" class="accent-[#FF6B00] w-3.5 h-3.5"> 3</div>
                                    </label>
                                    <label class="flex flex-col items-center gap-1.5 cursor-pointer active:scale-90 transition-transform">
                                        <span class="text-[28px]">😍</span>
                                        <div class="flex items-center gap-1 text-[12px] font-bold"><input type="radio" name="rating" value="5" class="accent-[#FF6B00] w-3.5 h-3.5"> 5</div>
                                    </label>
                                </div>
                                
                                <textarea name="comment" rows="2" placeholder="Leave a comment (optional)..." class="w-full bg-[#161A26] border border-transparent rounded-xl p-3 text-[13px] text-white focus:outline-none focus:border-white/30 transition-all mb-3 placeholder-white/40 shadow-inner"></textarea>
                                
                                <button type="submit" onclick="if(navigator.vibrate) navigator.vibrate(20)" class="w-full bg-white text-[#FF6B00] font-extrabold text-[14px] py-3 rounded-xl shadow-sm active:scale-95 transition-transform uppercase tracking-wider">
                                    Submit Feedback
                                </button>
                            </form>
                        </div>
                    <% } else { %>
                        <div class="bg-black/20 rounded-xl p-5 backdrop-blur-md border border-white/10 mt-2">
                            <h3 class="font-black text-[16px] text-[#FFD700]">You rated: <%= order.rating %> ⭐</h3>
                            <% if(order.comment) { %><p class="text-[13px] font-medium text-white/90 italic mt-2.5">"<%= order.comment %>"</p><% } %>
                            <p class="text-[11px] font-extrabold uppercase tracking-widest text-white/60 mt-4">Thank you for your feedback!</p>
                        </div>
                    <% } %>
                </div>
            </div>
        <% } %>
        
        <!-- Refresh Button -->
        <button onclick="if(navigator.vibrate) navigator.vibrate(15); window.location.reload()" class="w-full bg-[#11141E] hover:bg-[#161A26] active:scale-[0.98] border border-white/[0.04] text-white font-bold text-[14px] py-3.5 rounded-2xl transition-all shadow-sm flex items-center justify-center gap-2 animate-fade-in" style="animation-delay: 0.3s;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"></polyline><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"></path></svg>
            Refresh Status
        </button>
    </main>

    <!-- SOCKET.IO CLIENT SCRIPT -->
    <script src="/socket.io/socket.io.js"></script>
    <script>
        const socket = io();
        const orderId = '<%= order._id %>';
        const statusEl = document.getElementById('liveStatus');

        // Join the specific room for this order
        socket.emit('joinOrderRoom', orderId);

        // Listen for updates from the kitchen!
        socket.on('statusUpdated', (newStatus) => {
            statusEl.innerText = newStatus;
            
            // Visual feedback based on status
            if(newStatus === 'Preparing') {
                statusEl.className = "text-[32px] font-black text-yellow-400 leading-none tracking-tight relative z-10 animate-pulse pb-1";
            } else if (newStatus === 'Ready') {
                statusEl.className = "text-[32px] font-black text-emerald-400 leading-none tracking-tight relative z-10 animate-bounce pb-1";
                if (navigator.vibrate) navigator.vibrate([200, 100, 200]); // Haptic feedback when food is ready
            } else {
                statusEl.className = "text-[32px] font-black text-[#FF6B00] leading-none tracking-tight relative z-10 animate-pulse pb-1";
            }
        });
    </script>
</body>
</html>