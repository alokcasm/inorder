<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Welcome - <%= vendor.shopName %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        body { 
            font-family: 'Inter', sans-serif; 
            background-color: #121624; 
            color: #ffffff; 
        }
        .bg-gradient-primary { background-image: linear-gradient(135deg, #FF6B00, #FF3D3D); }
        
        /* Ultra-Clean App Animations */
        @keyframes popIn {
            0% { opacity: 0; transform: scale(0.9) translateY(10px); }
            100% { opacity: 1; transform: scale(1) translateY(0); }
        }
        @keyframes slideUpSheet {
            0% { transform: translateY(100%); }
            100% { transform: translateY(0); }
        }
        @keyframes fadeIn {
            0% { opacity: 0; }
            100% { opacity: 1; }
        }
        
        .pop-in { opacity: 0; animation: popIn 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
        .slide-up-sheet { animation: slideUpSheet 0.6s cubic-bezier(0.22, 1, 0.36, 1) forwards; }
        .fade-in { animation: fadeIn 1s ease-in-out forwards; }
        
        .delay-100 { animation-delay: 0.1s; }
        .delay-200 { animation-delay: 0.2s; }
        .delay-300 { animation-delay: 0.3s; }
        
        /* Input autofill fix for dark mode */
        input:-webkit-autofill {
            -webkit-box-shadow: 0 0 0 30px #0B0E16 inset !important;
            -webkit-text-fill-color: white !important;
        }
    </style>
</head>
<body class="flex flex-col h-[100dvh] relative overflow-hidden max-w-md mx-auto w-full sm:border-x border-white/5 shadow-2xl bg-[#121624]">
    
    <!-- Top Half: Full-Bleed Image Header -->
    <div class="relative w-full flex-1 min-h-[45%] fade-in">
        <!-- The Image -->
        <img src="/download.jpg" 
             alt="Welcome" 
             class="absolute inset-0 w-full h-full object-cover">
             
        <!-- Top Gradient (for table badge legibility) -->
        <div class="absolute inset-x-0 top-0 h-32 bg-gradient-to-b from-black/60 to-transparent"></div>
        
        <!-- Bottom Gradient (Seamlessly blends image into the form sheet) -->
        <div class="absolute inset-x-0 bottom-0 h-40 bg-gradient-to-t from-[#121624] via-[#121624]/80 to-transparent"></div>

        <!-- Table Badge (Glassmorphism overlay) -->
        <div class="absolute top-6 inset-x-0 flex justify-center z-10">
            <div class="pop-in inline-flex items-center gap-2 bg-black/30 backdrop-blur-md border border-white/20 px-4 py-2 rounded-full shadow-lg">
                <div class="w-2.5 h-2.5 rounded-full bg-emerald-400 animate-pulse shadow-[0_0_8px_rgba(52,211,153,0.8)]"></div>
                <p class="text-white text-xs font-bold tracking-widest uppercase text-shadow-sm">Table <%= table.tableNumber %></p>
            </div>
        </div>
    </div>

    <!-- Bottom Half: Native App Bottom Sheet -->
    <!-- Negative margin (-mt-8) makes it overlap the image cleanly -->
    <div class="shrink-0 slide-up-sheet w-full bg-[#121624] border-t border-white/[0.08] rounded-t-[2.5rem] p-6 pb-8 sm:p-8 sm:pb-10 shadow-[0_-15px_40px_rgba(0,0,0,0.5)] z-20 relative -mt-8">
        
        <!-- Subtle drag handle line -->
        <div class="w-12 h-1.5 bg-white/15 rounded-full mx-auto mb-6"></div>

        <div class="text-center mb-6 pop-in delay-100">
            <h1 class="text-2xl font-bold tracking-tight mb-1 text-white">
                <%= vendor.shopName %>
            </h1>
            <p class="text-gray-400 text-xs font-medium uppercase tracking-widest">Check in to see the menu</p>
        </div>

        <form action="/t/<%= table._id %>/join" method="POST" class="space-y-4">
            
            <!-- Name Input -->
            <div class="relative pop-in delay-200">
                <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#9ca3af" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
                </div>
                <input type="text" name="name" required 
                       class="w-full bg-[#0B0E16] border border-white/5 rounded-2xl pl-11 pr-5 py-4 text-white text-sm font-medium focus:outline-none focus:border-orange-500 focus:ring-1 focus:ring-orange-500 transition-all shadow-inner placeholder-gray-500" 
                       placeholder="Enter your name">
            </div>

            <!-- Phone Input -->
            <div class="relative pop-in delay-200">
                <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#9ca3af" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
                </div>
                <input type="tel" name="phone" required pattern="[0-9]{10}" 
                       class="w-full bg-[#0B0E16] border border-white/5 rounded-2xl pl-11 pr-5 py-4 text-white text-sm font-medium focus:outline-none focus:border-orange-500 focus:ring-1 focus:ring-orange-500 transition-all shadow-inner placeholder-gray-500" 
                       placeholder="Mobile number">
            </div>

            <!-- Submit Button -->
            <div class="pt-2 pop-in delay-300">
                <button type="submit" class="w-full bg-gradient-primary text-white font-bold text-base py-4 rounded-2xl shadow-[0_8px_20px_rgba(255,107,0,0.35)] active:scale-[0.98] transition-all duration-200 flex items-center justify-center gap-2 tracking-wide border border-white/10">
                    Open Menu
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-1"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </button>
            </div>
            
        </form>
    </div>

</body>
</html>