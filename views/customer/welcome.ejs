<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Welcome - <%= vendor.shopName %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <style>
        body { 
            font-family: 'Plus Jakarta Sans', sans-serif; 
            background-color: #07090F; 
            color: #ffffff; 
            -webkit-tap-highlight-color: transparent;
        }
        
        .bg-gradient-primary { background-image: linear-gradient(135deg, #FF6B00, #FF3D3D); }
        
        /* Ultra-Clean App Animations */
        @keyframes fadeDown { from { opacity: 0; transform: translateY(-15px); } to { opacity: 1; transform: translateY(0); } }
        @keyframes slideUpSheet { 0% { transform: translateY(100%); opacity: 0; } 100% { transform: translateY(0); opacity: 1; } }
        @keyframes fadeIn { 0% { opacity: 0; } 100% { opacity: 1; } }
        
        .animate-fade-down { animation: fadeDown 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
        .animate-slide-up { animation: slideUpSheet 0.7s cubic-bezier(0.22, 1, 0.36, 1) forwards; }
        .animate-fade-in { animation: fadeIn 1.2s ease-out forwards; }
        
        /* Staggered animation delays for the form elements */
        .delay-100 { animation-delay: 0.1s; }
        .delay-200 { animation-delay: 0.2s; }
        .delay-300 { animation-delay: 0.3s; }
        
        /* Input autofill fix for dark mode */
        input:-webkit-autofill,
        input:-webkit-autofill:hover, 
        input:-webkit-autofill:focus, 
        input:-webkit-autofill:active {
            -webkit-box-shadow: 0 0 0 30px #161A26 inset !important;
            -webkit-text-fill-color: white !important;
            transition: background-color 5000s ease-in-out 0s;
        }
    </style>
</head>
<body class="flex flex-col h-[100dvh] relative overflow-hidden max-w-md mx-auto w-full selection:bg-orange-500/30">
    
    <!-- Top Half: Full-Bleed Image Background -->
    <div class="absolute inset-0 w-full h-[65%] animate-fade-in z-0">
        <!-- The Image -->
        <img src="/download.jpg" 
             alt="Welcome" 
             class="w-full h-full object-cover">
             
        <!-- Top Gradient (for table badge legibility) -->
        <div class="absolute inset-x-0 top-0 h-32 bg-gradient-to-b from-[#07090F]/80 to-transparent"></div>
        
        <!-- Bottom Gradient (Seamlessly blends image into the background color) -->
        <div class="absolute inset-x-0 bottom-0 h-48 bg-gradient-to-t from-[#07090F] via-[#07090F]/80 to-transparent"></div>
    </div>

    <!-- Table Badge (Glassmorphism overlay) -->
    <div class="absolute top-6 inset-x-0 flex justify-center z-10">
        <div class="animate-fade-down inline-flex items-center gap-2.5 bg-black/40 backdrop-blur-xl border border-white/[0.08] px-4 py-2.5 rounded-full shadow-lg">
            <div class="w-2.5 h-2.5 rounded-full bg-emerald-400 animate-pulse shadow-[0_0_10px_rgba(52,211,153,0.6)]"></div>
            <p class="text-white text-[11px] font-extrabold tracking-widest uppercase mt-0.5">Table <%= table.tableNumber %></p>
        </div>
    </div>

    <!-- Spacer to push the bottom sheet down -->
    <div class="flex-1 z-0 pointer-events-none"></div>

    <!-- Bottom Half: Native App Bottom Sheet -->
    <div class="shrink-0 animate-slide-up w-full bg-[#11141E]/95 backdrop-blur-2xl border-t border-white/[0.04] rounded-t-[32px] p-6 pb-10 shadow-[0_-15px_40px_rgba(0,0,0,0.5)] z-20 relative flex flex-col">
        
        <!-- Subtle drag handle line -->
        <div class="w-12 h-1.5 bg-white/10 rounded-full mx-auto mb-6"></div>

        <div class="text-center mb-8">
            <h1 class="text-[26px] font-black tracking-tight text-white mb-1.5 leading-tight">
                <%= vendor.shopName %>
            </h1>
            <p class="text-[13px] font-medium text-gray-400">Please enter your details to view the menu</p>
        </div>

        <form action="/t/<%= table._id %>/join" method="POST" class="space-y-3.5">
            
            <!-- Name Input -->
            <div class="relative animate-fade-down delay-100 opacity-0" style="animation-fill-mode: forwards;">
                <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#9ca3af" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
                </div>
                <input type="text" name="name" required 
                       class="w-full bg-[#161A26] border border-transparent rounded-2xl pl-12 pr-5 py-4 text-white text-[14px] font-bold focus:outline-none focus:border-[#FF6B00]/40 focus:bg-white/5 transition-all shadow-sm placeholder-gray-500" 
                       placeholder="Enter your name">
            </div>

            <!-- Phone Input -->
            <div class="relative animate-fade-down delay-200 opacity-0" style="animation-fill-mode: forwards;">
                <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#9ca3af" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
                </div>
                <input type="tel" name="phone" required pattern="[0-9]{10}" 
                       class="w-full bg-[#161A26] border border-transparent rounded-2xl pl-12 pr-5 py-4 text-white text-[14px] font-bold focus:outline-none focus:border-[#FF6B00]/40 focus:bg-white/5 transition-all shadow-sm placeholder-gray-500" 
                       placeholder="Mobile number">
            </div>

            <!-- Submit Button -->
            <div class="pt-2 animate-fade-down delay-300 opacity-0" style="animation-fill-mode: forwards;">
                <button type="submit" onclick="if(navigator.vibrate) navigator.vibrate(20)" class="w-full bg-gradient-primary text-white font-extrabold text-[15px] py-4 rounded-2xl shadow-[0_8px_25px_rgba(255,107,0,0.3)] active:scale-[0.98] transition-all flex items-center justify-center gap-2 border border-orange-400/30 group">
                    Open Menu
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-1"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </button>
            </div>
            
        </form>
    </div>

</body>
</html>