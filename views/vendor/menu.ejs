<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Menu & QR Manager - inOrder</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #07090F; color: #ffffff; overflow-x: hidden; }
        .bg-gradient-primary { background-image: linear-gradient(135deg, #FF6B00, #FF3D3D); }
        
        /* Custom Scrollbar for the menu list */
        .custom-scrollbar::-webkit-scrollbar { width: 6px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: #0B0E16; border-radius: 8px; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: rgba(255, 255, 255, 0.1); border-radius: 8px; }
        .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: rgba(255, 107, 0, 0.5); }
    </style>
</head>
<body class="antialiased selection:bg-orange-500/30">

    <!-- ========================================= -->
    <!-- RESPONSIVE NAVBAR                         -->
    <!-- ========================================= -->
    <nav class="bg-[#0B0E16]/90 backdrop-blur-xl border-b border-white/[0.05] sticky top-0 z-40">
        <div class="max-w-7xl mx-auto px-5 sm:px-6 py-4 flex justify-between items-center">
            
            <!-- Logo -->
            <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-lg bg-gradient-primary flex items-center justify-center shadow-[0_0_15px_rgba(255,107,0,0.4)]">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
                </div>
                <span class="text-xl font-bold tracking-tight"><%= user.shopName %></span>
            </div>
            
            <!-- Desktop Links -->
            <div class="hidden lg:flex items-center gap-6">
                <a href="/vendor/dashboard" class="text-gray-400 hover:text-white font-medium transition">Live Orders</a>
                <a href="/vendor/menu" class="text-orange-500 font-medium">Menu & QR</a>
                <a href="/vendor/reports" class="text-gray-400 hover:text-white font-medium transition">Reports</a>
                <a href="/vendor/settings" class="text-gray-400 hover:text-white font-medium transition">Settings</a>
                <a href="/logout" class="bg-white/10 hover:bg-white/20 px-4 py-2 rounded-xl text-sm font-bold transition">Logout</a>
            </div>

            <!-- Mobile Hamburger Button -->
            <button onclick="openSidebar()" class="lg:hidden text-gray-300 hover:text-white p-1 focus:outline-none">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
            </button>
        </div>
    </nav>

    <!-- ========================================= -->
    <!-- MOBILE SIDEBAR (Off-canvas)               -->
    <!-- ========================================= -->
    <div id="sidebarOverlay" onclick="closeSidebar()" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-50 hidden opacity-0 transition-opacity duration-300"></div>

    <div id="mobileSidebar" class="fixed top-0 right-0 w-64 h-full bg-[#0B0E16] border-l border-white/5 z-[60] transform translate-x-full transition-transform duration-300 ease-in-out flex flex-col shadow-2xl">
        <div class="px-6 py-5 border-b border-white/5 flex justify-between items-center bg-[#121624]/50">
            <span class="font-extrabold text-white tracking-widest uppercase text-sm">Menu</span>
            <button onclick="closeSidebar()" class="text-gray-400 hover:text-white p-1 bg-white/5 rounded-full">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
            </button>
        </div>

        <div class="flex flex-col p-4 space-y-2 flex-1">
            <a href="/vendor/dashboard" class="flex items-center gap-3 px-4 py-3 rounded-xl text-gray-400 hover:text-white hover:bg-white/5 font-semibold transition-colors">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="3" y1="9" x2="21" y2="9"></line><line x1="9" y1="21" x2="9" y2="9"></line></svg>
                Live Orders
            </a>
            
            <!-- Active State for Menu & QR -->
            <a href="/vendor/menu" class="flex items-center gap-3 px-4 py-3 rounded-xl bg-orange-500/10 text-orange-500 border border-orange-500/20 font-bold transition-colors">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
                Menu & QR
            </a>

            <a href="/vendor/reports" class="flex items-center gap-3 px-4 py-3 rounded-xl text-gray-400 hover:text-white hover:bg-white/5 font-semibold transition-colors">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="20" x2="18" y2="10"></line><line x1="12" y1="20" x2="12" y2="4"></line><line x1="6" y1="20" x2="6" y2="14"></line></svg>
                Reports
            </a>
            <a href="/vendor/settings" class="flex items-center gap-3 px-4 py-3 rounded-xl text-gray-400 hover:text-white hover:bg-white/5 font-semibold transition-colors">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"></circle><path d="M19.4 15..."></path></svg>
                Settings
            </a>
        </div>

        <div class="p-5 border-t border-white/5">
            <a href="/logout" class="flex justify-center items-center gap-2 w-full bg-red-500/10 hover:bg-red-500/20 text-red-500 font-bold py-3.5 rounded-xl border border-red-500/20 transition-colors">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg>
                Sign Out
            </a>
        </div>
    </div>

    <!-- ========================================= -->
    <!-- MAIN CONTENT                              -->
    <!-- ========================================= -->
    <main class="max-w-7xl mx-auto px-5 sm:px-6 py-8">
        <div class="mb-8">
            <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight">Manage Menu & Tables</h1>
            <p class="text-gray-400 text-sm mt-1">Add your dishes, set offer prices, and print QR codes for your tables.</p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-10">
            
            <!-- LEFT COLUMN: MENU ITEMS (Spans 7 cols) -->
            <div class="lg:col-span-7 space-y-6">
                
                <!-- ADD ITEM FORM CARD -->
                <div class="bg-[#121624] border border-white/5 rounded-[2rem] p-6 sm:p-8 shadow-xl relative overflow-hidden">
                    <div class="absolute top-0 left-0 w-full h-1 bg-gradient-primary"></div>
                    <h2 class="text-xl font-bold mb-6 text-white flex items-center gap-2">
                        <span class="text-orange-500">➕</span> Add New Menu Item
                    </h2>
                    
                    <form action="/vendor/menu/add" method="POST" enctype="multipart/form-data" class="space-y-5">
                        
                        <!-- Row 1: Name -->
                        <div>
                            <label class="block text-[11px] font-bold text-gray-400 mb-1.5 uppercase tracking-wider">Item Name</label>
                            <input type="text" name="name" required class="w-full bg-[#0B0E16] border border-white/10 rounded-xl px-4 py-3 text-white text-sm focus:border-orange-500 focus:ring-1 focus:ring-orange-500 outline-none transition-all shadow-inner" placeholder="e.g. Paneer Butter Masala">
                        </div>

                        <!-- Row 2: Price, Offer Price, Diet Type -->
                        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                            <div>
                                <label class="block text-[11px] font-bold text-gray-400 mb-1.5 uppercase tracking-wider">Price (₹)</label>
                                <input type="number" name="price" required class="w-full bg-[#0B0E16] border border-white/10 rounded-xl px-4 py-3 text-white text-sm focus:border-orange-500 focus:ring-1 focus:ring-orange-500 outline-none transition-all shadow-inner" placeholder="e.g. 200">
                            </div>
                            <div>
                                <label class="block text-[11px] font-bold text-gray-400 mb-1.5 uppercase tracking-wider">Offer Price</label>
                                <input type="number" name="offerPrice" class="w-full bg-[#0B0E16] border border-white/10 rounded-xl px-4 py-3 text-white text-sm focus:border-orange-500 focus:ring-1 focus:ring-orange-500 outline-none transition-all shadow-inner" placeholder="Optional">
                            </div>
                            <div>
                                <label class="block text-[11px] font-bold text-gray-400 mb-1.5 uppercase tracking-wider">Diet Type</label>
                                <select name="dietType" class="w-full bg-[#0B0E16] border border-white/10 rounded-xl px-4 py-3 text-white text-sm focus:border-orange-500 outline-none transition-all shadow-inner appearance-none cursor-pointer">
                                    <option value="Veg">🟩 Veg</option>
                                    <option value="Non-Veg">🟥 Non-Veg</option>
                                </select>
                            </div>
                        </div>

                        <!-- Row 3: Category & Image -->
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                            <div>
                                <label class="block text-[11px] font-bold text-gray-400 mb-1.5 uppercase tracking-wider">Category</label>
                                <input type="text" name="category" list="categories" required class="w-full bg-[#0B0E16] border border-white/10 rounded-xl px-4 py-3 text-white text-sm focus:border-orange-500 focus:ring-1 focus:ring-orange-500 outline-none transition-all shadow-inner" placeholder="Type or select...">
                                <datalist id="categories">
                                    <option value="Starters"> <option value="Main Course"> <option value="Beverages"> <option value="Desserts"> <option value="Breads">
                                </datalist>
                            </div>
                            <div>
                                <label class="block text-[11px] font-bold text-gray-400 mb-1.5 uppercase tracking-wider">Food Image</label>
                                <input type="file" name="image" accept="image/*" class="w-full bg-[#0B0E16] border border-white/10 rounded-xl px-4 py-2 text-gray-400 text-sm focus:border-orange-500 outline-none transition-all shadow-inner file:mr-4 file:py-1 file:px-3 file:rounded-lg file:border-0 file:text-xs file:font-bold file:bg-white/10 file:text-white hover:file:bg-white/20 cursor-pointer">
                            </div>
                        </div>

                        <button type="submit" class="w-full bg-gradient-primary text-white font-bold rounded-xl py-3.5 mt-2 shadow-[0_5px_15px_rgba(255,107,0,0.3)] hover:-translate-y-0.5 transition-transform active:scale-95">
                            Save Item to Menu
                        </button>
                    </form>
                </div>

                <!-- LIST OF ITEMS CARD -->
                <div class="bg-[#121624] border border-white/5 rounded-[2rem] p-6 sm:p-8 shadow-xl">
                    <div class="flex justify-between items-center mb-6 border-b border-white/5 pb-4">
                        <h2 class="text-xl font-bold text-white">Your Menu</h2>
                        <span class="bg-white/10 text-white text-xs font-bold px-3 py-1 rounded-full"><%= items.length %> Items</span>
                    </div>

                    <% if (items.length === 0) { %>
                        <div class="text-center py-10 opacity-50">
                            <div class="text-4xl mb-2">📋</div>
                            <p class="text-sm">Your menu is empty.</p>
                        </div>
                    <% } else { %>
                        <div class="space-y-4 max-h-[600px] overflow-y-auto pr-2 custom-scrollbar">
                            <% items.forEach(item => { %>
                                <!-- Single Item Row -->
                                <div class="bg-[#0B0E16] border border-white/5 p-4 rounded-2xl flex flex-col gap-4 shadow-sm hover:border-white/10 transition-colors group">
                                    
                                    <!-- Display View -->
                                    <div class="flex justify-between items-start gap-4">
                                        <div class="flex items-start gap-3 flex-1">
                                            <!-- Image -->
                                            <div class="w-16 h-16 shrink-0 rounded-xl overflow-hidden bg-[#121624] border border-white/5">
                                                <img src="<%= item.image %>" class="w-full h-full object-cover">
                                            </div>
                                            <!-- Info -->
                                            <div>
                                                <div class="flex items-center gap-2 mb-1">
                                                    <!-- Veg/Non-Veg Icon -->
                                                    <% if(item.dietType === 'Non-Veg') { %>
                                                        <div class="w-3.5 h-3.5 border-2 border-red-500 flex items-center justify-center rounded-[3px] shrink-0"><div class="w-1.5 h-1.5 bg-red-500 rounded-full"></div></div>
                                                    <% } else if(item.dietType === 'Egg') { %>
                                                        <div class="w-3.5 h-3.5 border-2 border-yellow-500 flex items-center justify-center rounded-[3px] shrink-0"><div class="w-1.5 h-1.5 bg-yellow-500 rounded-full"></div></div>
                                                    <% } else { %>
                                                        <div class="w-3.5 h-3.5 border-2 border-green-500 flex items-center justify-center rounded-[3px] shrink-0"><div class="w-1.5 h-1.5 bg-green-500 rounded-full"></div></div>
                                                    <% } %>
                                                    <h4 class="font-bold text-white leading-tight text-sm sm:text-base"><%= item.name %></h4>
                                                </div>
                                                
                                                <p class="text-[10px] font-bold uppercase tracking-wider text-gray-500 mb-1.5"><%= item.category %></p>
                                                
                                                <div class="flex items-center gap-2">
                                                    <span class="text-orange-400 font-extrabold">₹<%= item.offerPrice ? item.offerPrice : item.price %></span>
                                                    <% if(item.offerPrice) { %>
                                                        <span class="text-gray-500 line-through text-xs font-medium">₹<%= item.price %></span>
                                                    <% } %>
                                                </div>
                                            </div>
                                        </div>

                                        <!-- Actions (Edit / Delete) -->
                                        <div class="flex flex-col sm:flex-row items-center gap-2 shrink-0">
                                            <button onclick="document.getElementById('edit-<%= item._id %>').classList.toggle('hidden')" class="bg-blue-500/10 text-blue-400 hover:bg-blue-500/20 p-2.5 rounded-xl transition w-full sm:w-auto flex justify-center">
                                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
                                            </button>
                                            <form action="/vendor/menu/delete/<%= item._id %>" method="POST" onsubmit="return confirm('Are you sure you want to delete this item?');" class="w-full sm:w-auto">
                                                <button type="submit" class="bg-red-500/10 text-red-500 hover:bg-red-500/20 p-2.5 rounded-xl transition w-full flex justify-center">
                                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
                                                </button>
                                            </form>
                                        </div>
                                    </div>

                                    <!-- HIDDEN EDIT FORM -->
                                    <form id="edit-<%= item._id %>" action="/vendor/menu/edit/<%= item._id %>" method="POST" enctype="multipart/form-data" class="hidden bg-[#121624] p-5 rounded-xl border border-white/10 mt-2 space-y-4">
                                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                                            <div>
                                                <label class="text-[10px] text-gray-400 uppercase tracking-widest mb-1 block">Name</label>
                                                <input type="text" name="name" value="<%= item.name %>" class="w-full bg-[#0B0E16] rounded-lg px-3 py-2 text-sm text-white border border-white/5 focus:border-orange-500 outline-none">
                                            </div>
                                            <div>
                                                <label class="text-[10px] text-gray-400 uppercase tracking-widest mb-1 block">Diet Type</label>
                                                <select name="dietType" class="w-full bg-[#0B0E16] rounded-lg px-3 py-2 text-sm text-white border border-white/5 outline-none">
                                                    <option value="Veg" <%= item.dietType == 'Veg' ? 'selected' : '' %>>🟩 Veg</option>
                                                    <option value="Non-Veg" <%= item.dietType == 'Non-Veg' ? 'selected' : '' %>>🟥 Non-Veg</option>
                                                </select>
                                            </div>
                                        </div>

                                        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
                                            <div class="col-span-2">
                                                <label class="text-[10px] text-gray-400 uppercase tracking-widest mb-1 block">Category</label>
                                                <input type="text" name="category" list="categories" value="<%= item.category %>" class="w-full bg-[#0B0E16] rounded-lg px-3 py-2 text-sm text-white border border-white/5 outline-none">
                                            </div>
                                            <div>
                                                <label class="text-[10px] text-gray-400 uppercase tracking-widest mb-1 block">Price</label>
                                                <input type="number" name="price" value="<%= item.price %>" class="w-full bg-[#0B0E16] rounded-lg px-3 py-2 text-sm text-white border border-white/5 outline-none">
                                            </div>
                                            <div>
                                                <label class="text-[10px] text-gray-400 uppercase tracking-widest mb-1 block">Offer Price</label>
                                                <input type="number" name="offerPrice" value="<%= item.offerPrice || '' %>" class="w-full bg-[#0B0E16] rounded-lg px-3 py-2 text-sm text-white border border-white/5 outline-none">
                                            </div>
                                        </div>

                                        <div>
                                            <label class="text-[10px] text-gray-400 uppercase tracking-widest mb-1 block">Update Image (Leave blank to keep current)</label>
                                            <input type="file" name="image" accept="image/*" class="w-full bg-[#0B0E16] rounded-lg px-3 py-1.5 text-xs text-gray-400 border border-white/5 outline-none file:mr-3 file:py-1 file:px-3 file:rounded file:border-0 file:text-xs file:font-bold file:bg-white/10 file:text-white">
                                        </div>

                                        <button type="submit" class="w-full bg-blue-500 hover:bg-blue-600 text-white rounded-lg py-2.5 text-sm font-bold shadow-lg transition">Save Changes</button>
                                    </form>

                                </div>
                            <% }) %>
                        </div>
                    <% } %>
                </div>
            </div>

            <!-- ========================================== -->
            <!-- RIGHT COLUMN: QR CODES & TABLES (Spans 5)  -->
            <!-- ========================================== -->
            <div class="lg:col-span-5 space-y-6">
                
                <!-- ADD TABLE CARD -->
                <div class="bg-[#121624] border border-white/5 rounded-[2rem] p-6 sm:p-8 shadow-xl relative overflow-hidden">
                    <div class="absolute top-0 left-0 w-full h-1 bg-emerald-500"></div>
                    <h2 class="text-xl font-bold mb-2 text-white flex items-center gap-2">
                        <span class="text-emerald-400">🖨️</span> Generate Table QR
                    </h2>
                    <p class="text-xs text-gray-400 mb-6">Create a unique QR code for each physical table in your restaurant.</p>
                    
                    <form action="/vendor/table/add" method="POST" class="flex flex-col sm:flex-row gap-4 items-end">
                        <div class="w-full sm:flex-1">
                            <label class="block text-[11px] font-bold text-gray-400 mb-1.5 uppercase tracking-wider">Table Number</label>
                            <input type="number" name="tableNumber" required min="1" class="w-full bg-[#0B0E16] border border-white/10 rounded-xl px-4 py-3 text-white text-sm focus:border-emerald-500 outline-none transition-shadow shadow-inner" placeholder="e.g. 1">
                        </div>
                        <button type="submit" class="w-full sm:w-auto bg-emerald-500 hover:bg-emerald-600 text-white font-bold rounded-xl px-6 py-3 shadow-[0_5px_15px_rgba(16,185,129,0.3)] transition active:scale-95">
                            Generate
                        </button>
                    </form>
                </div>

                <!-- LIST OF TABLES & QR CODES -->
                <div class="bg-[#121624] border border-white/5 rounded-[2rem] p-6 sm:p-8 shadow-xl">
                    <div class="flex justify-between items-center mb-6 border-b border-white/5 pb-4">
                        <h2 class="text-xl font-bold text-white">Your Tables</h2>
                        <span class="bg-white/10 text-white text-xs font-bold px-3 py-1 rounded-full"><%= tables.length %> Active</span>
                    </div>

                    <% if (tables.length === 0) { %>
                        <div class="text-center py-8 opacity-50">
                            <p class="text-sm text-gray-400">No tables added yet.</p>
                        </div>
                    <% } else { %>
                        <div class="grid grid-cols-2 gap-4 max-h-[500px] overflow-y-auto pr-2 custom-scrollbar">
                            <% tables.forEach(table => { %>
                                <div class="bg-[#0B0E16] border border-white/5 p-4 rounded-2xl flex flex-col items-center text-center group hover:border-emerald-500/30 transition-colors">
                                    <h4 class="font-extrabold text-white mb-3 tracking-wide">Table <%= table.tableNumber %></h4>
                                    
                                    <!-- Display QR Code -->
                                    <div class="bg-white p-2 rounded-xl mb-4 shadow-sm group-hover:scale-105 transition-transform">
                                        <img src="<%= table.qrCodeUrl %>" alt="QR Code" class="w-full h-auto rounded-lg">
                                    </div>
                                    
                                    <!-- Download Button -->
                                    <a href="<%= table.qrCodeUrl %>" download="Table_<%= table.tableNumber %>_QR.png" class="flex items-center justify-center gap-1.5 text-xs font-bold bg-white/10 hover:bg-white/20 py-2 px-4 rounded-xl text-gray-200 w-full transition">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
                                        Save
                                    </a>
                                </div>
                            <% }) %>
                        </div>
                    <% } %>
                </div>

            </div>
        </div>
    </main>

    <!-- Script for Sidebar Toggle -->
    <script>
        const sidebar = document.getElementById('mobileSidebar');
        const overlay = document.getElementById('sidebarOverlay');

        function openSidebar() {
            overlay.classList.remove('hidden');
            setTimeout(() => overlay.classList.remove('opacity-0'), 10);
            sidebar.classList.remove('translate-x-full');
            document.body.style.overflow = 'hidden'; 
        }

        function closeSidebar() {
            sidebar.classList.add('translate-x-full');
            overlay.classList.add('opacity-0');
            setTimeout(() => overlay.classList.add('hidden'), 300);
            document.body.style.overflow = '';
        }
    </script>
</body>
</html>