<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Menu & QR Manager - inOrder</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        body { 
            font-family: 'Plus Jakarta Sans', sans-serif; 
            background-color: #07090F; 
            color: #ffffff; 
            overflow-x: hidden; 
        }
        
        .bg-gradient-primary { background-image: linear-gradient(135deg, #FF6B00, #FF3D3D); }
        .text-gradient-primary { 
            background: linear-gradient(135deg, #FF6B00, #FF3D3D);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        
        /* Premium Custom Scrollbar */
        .custom-scrollbar::-webkit-scrollbar { width: 4px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: rgba(255, 255, 255, 0.1); border-radius: 10px; }
        .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: rgba(255, 107, 0, 0.5); }
        
        /* Smooth fade in */
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
        .animate-fade-in { animation: fadeIn 0.4s ease forwards; }
    </style>
</head>
<body class="antialiased selection:bg-orange-500/30">

    <!-- ========================================= -->
    <!-- RESPONSIVE NAVBAR                         -->
    <!-- ========================================= -->
    <nav class="bg-[#0B0E16]/90 backdrop-blur-xl border-b border-white/[0.05] sticky top-0 z-40">
        <div class="max-w-7xl mx-auto px-5 sm:px-6 py-4 flex justify-between items-center">
            
            <!-- Logo -->
            <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-lg bg-gradient-primary flex items-center justify-center shadow-[0_0_15px_rgba(255,107,0,0.4)]">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
                </div>
                <span class="text-xl font-bold tracking-tight"><%= user.shopName %></span>
            </div>
            
            <!-- Desktop Links -->
            <div class="hidden lg:flex items-center gap-6">
                <a href="/vendor/dashboard" class="text-gray-400 hover:text-white font-medium transition">Live Orders</a>
                <a href="/vendor/menu" class="text-orange-500 font-medium">Menu & QR</a>
                <a href="/vendor/reports" class="text-gray-400 hover:text-white font-medium transition">Reports</a>
                <a href="/vendor/settings" class="text-gray-400 hover:text-white font-medium transition">Settings</a>
                <a href="/logout" class="bg-white/10 hover:bg-white/20 px-4 py-2 rounded-xl text-sm font-bold transition">Logout</a>
            </div>

            <!-- Mobile Hamburger Button -->
            <button onclick="openSidebar()" class="lg:hidden text-gray-300 hover:text-white p-1 focus:outline-none">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
            </button>
        </div>
    </nav>

    <!-- ========================================= -->
    <!-- MOBILE SIDEBAR (Off-canvas)               -->
    <!-- ========================================= -->
    <div id="sidebarOverlay" onclick="closeSidebar()" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-50 hidden opacity-0 transition-opacity duration-300"></div>

    <div id="mobileSidebar" class="fixed top-0 right-0 w-64 h-full bg-[#0B0E16] border-l border-white/5 z-[60] transform translate-x-full transition-transform duration-300 ease-in-out flex flex-col shadow-2xl">
        <div class="px-6 py-5 border-b border-white/5 flex justify-between items-center bg-[#121624]/50">
            <span class="font-extrabold text-white tracking-widest uppercase text-sm">Menu</span>
            <button onclick="closeSidebar()" class="text-gray-400 hover:text-white p-1 bg-white/5 rounded-full">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
            </button>
        </div>

        <div class="flex flex-col p-4 space-y-2 flex-1">
            <!-- Active State for Dashboard -->
            <a href="/vendor/dashboard" class="flex items-center gap-3 px-4 py-3 rounded-xl text-gray-400 hover:text-white hover:bg-white/5 font-semibold transition-colors">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="3" y1="9" x2="21" y2="9"></line><line x1="9" y1="21" x2="9" y2="9"></line></svg>
                Live Orders
            </a>
            <a href="/vendor/menu" class="flex items-center gap-3 px-4 py-3 rounded-xl bg-orange-500/10 text-orange-500 border border-orange-500/20 font-bold transition-colors">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
                Menu & QR
            </a>
            <a href="/vendor/reports" class="flex items-center gap-3 px-4 py-3 rounded-xl text-gray-400 hover:text-white hover:bg-white/5 font-semibold transition-colors">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="20" x2="18" y2="10"></line><line x1="12" y1="20" x2="12" y2="4"></line><line x1="6" y1="20" x2="6" y2="14"></line></svg>
                Reports
            </a>
            <a href="/vendor/settings" class="flex items-center gap-3 px-4 py-3 rounded-xl text-gray-400 hover:text-white hover:bg-white/5 font-semibold transition-colors">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"></circle><path d="M19.4 15..."></path></svg>
                Settings
            </a>
        </div>

        <div class="p-5 border-t border-white/5">
            <a href="/logout" class="flex justify-center items-center gap-2 w-full bg-red-500/10 hover:bg-red-500/20 text-red-500 font-bold py-3.5 rounded-xl border border-red-500/20 transition-colors">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg>
                Sign Out
            </a>
        </div>
    </div>

    <!-- ========================================= -->
    <!-- MAIN CONTENT                              -->
    <!-- ========================================= -->
    <main class="max-w-[1400px] mx-auto px-4 sm:px-6 py-10">
        <div class="mb-10 animate-fade-in">
            <h1 class="text-[28px] sm:text-[36px] font-black tracking-tight leading-tight">Manage Menu & Tables</h1>
            <p class="text-gray-400 text-[14px] font-medium mt-1.5">Add dishes, update stock, and print beautiful QR codes for your tables.</p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-10">
            
            <!-- LEFT COLUMN: MENU ITEMS (Spans 7 cols) -->
            <div class="lg:col-span-7 space-y-8">
                
                <!-- ADD ITEM FORM CARD -->
                <div class="bg-[#11141E] border border-white/[0.04] rounded-[24px] p-6 sm:p-8 shadow-sm relative overflow-hidden animate-fade-in" style="animation-delay: 0.1s;">
                    <div class="absolute top-0 left-0 w-full h-1 bg-gradient-primary"></div>
                    
                    <h2 class="text-[18px] font-black mb-6 text-white flex items-center gap-2.5 tracking-tight">
                        <div class="bg-orange-500/10 p-2 rounded-lg text-orange-500 border border-orange-500/20">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                        </div>
                        Add New Item
                    </h2>
                    
                    <form action="/vendor/menu/add" method="POST" enctype="multipart/form-data" class="space-y-5">
                        
                        <!-- Row 1: Name -->
                        <div>
                            <label class="block text-[10px] font-extrabold text-gray-500 mb-2 uppercase tracking-widest pl-1">Item Name</label>
                            <input type="text" name="name" required class="w-full bg-[#161A26] border border-transparent rounded-xl px-4 py-3.5 text-white text-[13px] font-bold focus:border-orange-500/40 focus:bg-white/5 outline-none transition-all placeholder-gray-600 shadow-inner" placeholder="e.g. Paneer Butter Masala">
                        </div>

                        <!-- Row 2: Price, Offer Price, Diet Type -->
                        <div class="grid grid-cols-1 sm:grid-cols-3 gap-5">
                            <div>
                                <label class="block text-[10px] font-extrabold text-gray-500 mb-2 uppercase tracking-widest pl-1">Price (₹)</label>
                                <input type="number" name="price" required class="w-full bg-[#161A26] border border-transparent rounded-xl px-4 py-3.5 text-white text-[13px] font-bold focus:border-orange-500/40 focus:bg-white/5 outline-none transition-all placeholder-gray-600 shadow-inner" placeholder="e.g. 250">
                            </div>
                            <div>
                                <label class="block text-[10px] font-extrabold text-gray-500 mb-2 uppercase tracking-widest pl-1">Offer Price</label>
                                <input type="number" name="offerPrice" class="w-full bg-[#161A26] border border-transparent rounded-xl px-4 py-3.5 text-white text-[13px] font-bold focus:border-orange-500/40 focus:bg-white/5 outline-none transition-all placeholder-gray-600 shadow-inner" placeholder="Optional">
                            </div>
                            <div>
                                <label class="block text-[10px] font-extrabold text-gray-500 mb-2 uppercase tracking-widest pl-1">Diet Type</label>
                                <select name="dietType" class="w-full bg-[#161A26] border border-transparent rounded-xl px-4 py-3.5 text-white text-[13px] font-bold focus:border-orange-500/40 focus:bg-white/5 outline-none transition-all shadow-inner appearance-none cursor-pointer">
                                    <option value="Veg">🟩 Pure Veg</option>
                                    <option value="Non-Veg">🟥 Non-Veg</option>
                                </select>
                            </div>
                        </div>

                        <!-- Row 3: Category & Image -->
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                            <div>
                                <label class="block text-[10px] font-extrabold text-gray-500 mb-2 uppercase tracking-widest pl-1">Category</label>
                                <input type="text" name="category" list="categories" required class="w-full bg-[#161A26] border border-transparent rounded-xl px-4 py-3.5 text-white text-[13px] font-bold focus:border-orange-500/40 focus:bg-white/5 outline-none transition-all placeholder-gray-600 shadow-inner" placeholder="Type or select...">
                                <datalist id="categories">
                                    <option value="Starters"> <option value="Main Course"> <option value="Beverages"> <option value="Desserts"> <option value="Breads">
                                </datalist>
                            </div>
                            <div>
                                <label class="block text-[10px] font-extrabold text-gray-500 mb-2 uppercase tracking-widest pl-1">Food Image</label>
                                <input type="file" name="image" accept="image/*" class="w-full bg-[#161A26] border border-transparent rounded-xl px-4 py-2.5 text-gray-400 text-[12px] font-medium focus:border-orange-500/40 focus:bg-white/5 outline-none transition-all shadow-inner file:mr-4 file:py-1.5 file:px-4 file:rounded-lg file:border-0 file:text-[11px] file:font-extrabold file:bg-[#11141E] file:text-white file:border file:border-white/10 hover:file:bg-white/10 cursor-pointer">
                            </div>
                        </div>

                        <button type="submit" class="w-full bg-gradient-primary text-white font-extrabold text-[14px] rounded-xl py-4 mt-3 shadow-[0_8px_25px_rgba(255,107,0,0.3)] hover:-translate-y-0.5 transition-all active:scale-[0.98] border border-orange-400/30 uppercase tracking-wide">
                            Save Item to Menu
                        </button>
                    </form>
                </div>

                <!-- LIST OF ITEMS CARD -->
                <div class="bg-[#11141E] border border-white/[0.04] rounded-[24px] p-6 sm:p-8 shadow-sm animate-fade-in" style="animation-delay: 0.2s;">
                    <div class="flex justify-between items-center mb-6 border-b border-white/[0.04] pb-5">
                        <h2 class="text-[18px] font-black text-white tracking-tight">Your Menu</h2>
                        <span class="bg-white/5 border border-white/5 text-gray-300 text-[11px] font-bold px-3.5 py-1.5 rounded-full"><%= items.length %> Items</span>
                    </div>

                    <% if (items.length === 0) { %>
                        <div class="text-center py-12 flex flex-col items-center">
                            <div class="w-20 h-20 bg-[#161A26] rounded-full flex items-center justify-center mb-4 border border-white/5">
                                <span class="text-3xl opacity-50">📋</span>
                            </div>
                            <p class="text-[13px] text-gray-400 font-medium">Your menu is empty.</p>
                        </div>
                    <% } else { %>
                        <div class="space-y-4 max-h-[600px] overflow-y-auto pr-3 custom-scrollbar">
                            <% items.forEach(item => { %>
                                <!-- Single Item Row (Card Layout) -->
                                <div class="bg-[#161A26] border border-white/[0.03] p-4 rounded-2xl flex flex-col gap-4 shadow-sm hover:border-white/10 transition-colors group">
                                    
                                    <!-- Display View -->
                                    <div class="flex flex-col sm:flex-row justify-between items-start gap-4">
                                        <div class="flex items-start gap-4 flex-1">
                                            <!-- Image -->
                                            <div class="w-20 h-20 shrink-0 rounded-xl overflow-hidden bg-[#11141E] border border-white/5 relative <%= !item.isAvailable ? 'grayscale opacity-60' : '' %>">
                                                <img src="<%= item.image %>" class="w-full h-full object-cover">
                                                <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent"></div>
                                            </div>
                                            <!-- Info -->
                                            <div class="<%= !item.isAvailable ? 'opacity-60' : '' %>">
                                                <div class="flex items-center gap-2 mb-1.5">
                                                    <% if(item.dietType === 'Non-Veg') { %>
                                                        <div class="w-3.5 h-3.5 border border-red-500 flex items-center justify-center rounded-[3px] shrink-0"><div class="w-1.5 h-1.5 bg-red-500 rounded-full"></div></div>
                                                    <% } else if(item.dietType === 'Egg') { %>
                                                        <div class="w-3.5 h-3.5 border border-yellow-500 flex items-center justify-center rounded-[3px] shrink-0"><div class="w-1.5 h-1.5 bg-yellow-500 rounded-full"></div></div>
                                                    <% } else { %>
                                                        <div class="w-3.5 h-3.5 border border-green-500 flex items-center justify-center rounded-[3px] shrink-0"><div class="w-1.5 h-1.5 bg-green-500 rounded-full"></div></div>
                                                    <% } %>
                                                    <h4 class="font-bold text-white leading-tight text-[15px]"><%= item.name %></h4>
                                                </div>
                                                
                                                <p class="text-[10px] font-extrabold uppercase tracking-widest text-gray-500 mb-2"><%= item.category %></p>
                                                
                                                <div class="flex items-baseline gap-2">
                                                    <span class="text-gray-100 font-bold text-[15px]">₹<%= item.offerPrice ? item.offerPrice : item.price %></span>
                                                    <% if(item.offerPrice) { %>
                                                        <span class="text-gray-500 line-through text-[11px] font-semibold">₹<%= item.price %></span>
                                                    <% } %>
                                                </div>
                                            </div>
                                        </div>

                                        <!-- Actions (Stock / Edit / Delete) -->
                                        <div class="flex sm:flex-col items-center gap-2 shrink-0 w-full sm:w-auto">
                                            
                                            <!-- OUT OF STOCK TOGGLE -->
                                            <form action="/vendor/menu/toggle-stock/<%= item._id %>" method="POST" class="w-full">
                                                <button type="submit" class="py-2 px-3 rounded-lg transition-all w-full flex justify-center text-[11px] font-extrabold uppercase tracking-wide border <%= item.isAvailable ? 'bg-emerald-500/10 text-emerald-400 border-emerald-500/20 hover:bg-emerald-500/20' : 'bg-red-500/10 text-red-400 border-red-500/20 hover:bg-red-500/20' %>">
                                                    <%= item.isAvailable ? 'In Stock' : 'Out of Stock' %>
                                                </button>
                                            </form>

                                            <div class="flex gap-2 w-full">
                                                <!-- EDIT BUTTON -->
                                                <button onclick="document.getElementById('edit-<%= item._id %>').classList.toggle('hidden')" class="bg-[#11141E] text-blue-400 border border-white/5 hover:bg-white/5 py-2 px-3 rounded-lg transition-colors flex-1 flex justify-center">
                                                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
                                                </button>
                                                
                                                <!-- DELETE BUTTON -->
                                                <form action="/vendor/menu/delete/<%= item._id %>" method="POST" onsubmit="return confirm('Are you sure you want to delete this item?');" class="flex-1 flex">
                                                    <button type="submit" class="bg-[#11141E] text-red-500 border border-white/5 hover:bg-red-500/10 py-2 px-3 rounded-lg transition-colors w-full flex justify-center">
                                                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
                                                    </button>
                                                </form>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- HIDDEN EDIT FORM (Nested properly inside the item card) -->
                                    <form id="edit-<%= item._id %>" action="/vendor/menu/edit/<%= item._id %>" method="POST" enctype="multipart/form-data" class="hidden bg-[#11141E] p-5 rounded-xl border border-white/5 mt-2 space-y-4">
                                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                                            <div>
                                                <label class="text-[10px] text-gray-500 uppercase tracking-widest mb-1.5 block font-extrabold pl-1">Name</label>
                                                <input type="text" name="name" value="<%= item.name %>" class="w-full bg-[#161A26] rounded-xl px-4 py-2.5 text-[13px] font-bold text-white border border-transparent focus:border-orange-500/40 outline-none transition-colors">
                                            </div>
                                            <div>
                                                <label class="text-[10px] text-gray-500 uppercase tracking-widest mb-1.5 block font-extrabold pl-1">Diet Type</label>
                                                <select name="dietType" class="w-full bg-[#161A26] rounded-xl px-4 py-2.5 text-[13px] font-bold text-white border border-transparent focus:border-orange-500/40 outline-none transition-colors appearance-none">
                                                    <option value="Veg" <%= item.dietType == 'Veg' ? 'selected' : '' %>>🟩 Veg</option>
                                                    <option value="Non-Veg" <%= item.dietType == 'Non-Veg' ? 'selected' : '' %>>🟥 Non-Veg</option>
                                                </select>
                                            </div>
                                        </div>

                                        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
                                            <div class="col-span-2">
                                                <label class="text-[10px] text-gray-500 uppercase tracking-widest mb-1.5 block font-extrabold pl-1">Category</label>
                                                <input type="text" name="category" list="categories" value="<%= item.category %>" class="w-full bg-[#161A26] rounded-xl px-4 py-2.5 text-[13px] font-bold text-white border border-transparent focus:border-orange-500/40 outline-none transition-colors">
                                            </div>
                                            <div>
                                                <label class="text-[10px] text-gray-500 uppercase tracking-widest mb-1.5 block font-extrabold pl-1">Price</label>
                                                <input type="number" name="price" value="<%= item.price %>" class="w-full bg-[#161A26] rounded-xl px-4 py-2.5 text-[13px] font-bold text-white border border-transparent focus:border-orange-500/40 outline-none transition-colors">
                                            </div>
                                            <div>
                                                <label class="text-[10px] text-gray-500 uppercase tracking-widest mb-1.5 block font-extrabold pl-1">Offer Price</label>
                                                <input type="number" name="offerPrice" value="<%= item.offerPrice || '' %>" class="w-full bg-[#161A26] rounded-xl px-4 py-2.5 text-[13px] font-bold text-white border border-transparent focus:border-orange-500/40 outline-none transition-colors">
                                            </div>
                                        </div>

                                        <div>
                                            <label class="text-[10px] text-gray-500 uppercase tracking-widest mb-1.5 block font-extrabold pl-1">Update Image (Optional)</label>
                                            <input type="file" name="image" accept="image/*" class="w-full bg-[#161A26] rounded-xl px-3 py-1.5 text-[12px] font-medium text-gray-400 border border-transparent outline-none file:mr-3 file:py-1.5 file:px-3 file:rounded-md file:border-0 file:text-[11px] file:font-extrabold file:bg-[#11141E] file:text-white file:border file:border-white/10 cursor-pointer">
                                        </div>

                                        <button type="submit" class="w-full bg-[#f8f9fa] text-[#07090F] rounded-xl py-3 text-[13px] font-black tracking-wide shadow-md transition-all active:scale-98 mt-2 uppercase">Save Changes</button>
                                    </form>

                                </div>
                            <% }) %>
                        </div>
                    <% } %>
                </div>
            </div>

            <!-- ========================================== -->
            <!-- RIGHT COLUMN: QR CODES & TABLES (Spans 5)  -->
            <!-- ========================================== -->
            <div class="lg:col-span-5 space-y-8">
                
                <!-- ADD TABLE CARD (Emerald Theme) -->
                <div class="bg-[#11141E] border border-white/[0.04] rounded-[24px] p-6 sm:p-8 shadow-sm relative overflow-hidden animate-fade-in" style="animation-delay: 0.3s;">
                    <div class="absolute top-0 left-0 w-full h-1 bg-emerald-500"></div>
                    
                    <h2 class="text-[18px] font-black mb-1.5 text-white flex items-center gap-2.5 tracking-tight">
                        <div class="bg-emerald-500/10 p-2 rounded-lg text-emerald-400 border border-emerald-500/20">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><rect x="7" y="7" width="3" height="3"></rect><rect x="14" y="7" width="3" height="3"></rect><rect x="7" y="14" width="3" height="3"></rect><rect x="14" y="14" width="3" height="3"></rect></svg>
                        </div>
                        Generate Table QR
                    </h2>
                    <p class="text-[13px] text-gray-400 font-medium mb-6">Create a unique scannable QR code for physical tables.</p>
                    
                    <form action="/vendor/table/add" method="POST" class="flex flex-col sm:flex-row gap-3 items-end">
                        <div class="w-full sm:flex-1">
                            <label class="block text-[10px] font-extrabold text-gray-500 mb-2 uppercase tracking-widest pl-1">Table Number</label>
                            <input type="number" name="tableNumber" required min="1" class="w-full bg-[#161A26] border border-transparent rounded-xl px-4 py-3.5 text-white text-[13px] font-bold focus:border-emerald-500/50 focus:bg-white/5 outline-none transition-all placeholder-gray-600 shadow-inner" placeholder="e.g. 5">
                        </div>
                        <button type="submit" class="w-full sm:w-auto bg-emerald-500 hover:bg-emerald-600 text-white font-extrabold text-[13px] rounded-xl px-7 py-3.5 shadow-[0_5px_20px_rgba(16,185,129,0.25)] transition-all active:scale-95 border border-emerald-400/30 uppercase tracking-wide h-[48px]">
                            Generate
                        </button>
                    </form>
                </div>

                <!-- LIST OF TABLES & QR CODES -->
                <div class="grid grid-cols-2 gap-4 max-h-[600px] overflow-y-auto pr-2 custom-scrollbar animate-fade-in" style="animation-delay: 0.4s;">
                    <% tables.forEach(table => { %>
                        <div class="bg-[#11141E] border border-white/[0.04] p-4 rounded-2xl flex flex-col items-center text-center group hover:border-emerald-500/30 transition-colors relative shadow-sm">
                            
                            <!-- DELETE TABLE BUTTON -->
                            <form action="/vendor/table/delete/<%= table._id %>" method="POST" onsubmit="return confirm('Delete this Table QR code forever?');" class="absolute top-2 right-2">
                                <button type="submit" class="bg-[#161A26] border border-white/5 hover:bg-red-500/20 hover:text-red-400 text-gray-500 p-2 rounded-lg transition-colors">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
                                </button>
                            </form>

                            <h4 class="font-black text-white text-[15px] mb-3 tracking-wide mt-2">Table <%= table.tableNumber %></h4>
                            
                            <!-- QR Code Container -->
                            <div class="bg-white p-2.5 rounded-xl mb-4 shadow-md group-hover:scale-105 transition-transform duration-300 w-full aspect-square flex items-center justify-center">
                                <img src="<%= table.qrCodeUrl %>" alt="QR Code" class="w-full h-full object-contain">
                            </div>
                            
                            <!-- Download Button -->
                            <a href="<%= table.qrCodeUrl %>" download="Table_<%= table.tableNumber %>_QR.png" class="flex items-center justify-center gap-2 text-[11px] font-extrabold uppercase tracking-wide bg-[#161A26] border border-white/5 hover:bg-white/10 py-2.5 px-4 rounded-xl text-white w-full transition-all active:scale-95 shadow-sm">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
                                Save QR
                            </a>
                        </div>
                    <% }) %>
                </div>

            </div>
        </div>
    </main>

    <!-- Script for Sidebar Toggle -->
    <script>
        const sidebar = document.getElementById('mobileSidebar');
        const overlay = document.getElementById('sidebarOverlay');

        function openSidebar() {
            overlay.classList.remove('hidden');
            setTimeout(() => overlay.classList.remove('opacity-0'), 10);
            sidebar.classList.remove('translate-x-full');
            document.body.style.overflow = 'hidden'; 
        }

        function closeSidebar() {
            sidebar.classList.add('translate-x-full');
            overlay.classList.add('opacity-0');
            setTimeout(() => overlay.classList.add('hidden'), 300);
            document.body.style.overflow = '';
        }
    </script>
</body>
</html>