<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Menu & QR Manager - inOrder</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #07090F; color: #ffffff; }
        .bg-gradient-primary { background-image: linear-gradient(to right, #FF6B00, #FF3D3D); }
    </style>
</head>
<body class="antialiased selection:bg-orange-500/30">

    <!-- Navbar -->
    <nav class="bg-[#0B0E16] border-b border-white/[0.05] sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center">
            <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-lg bg-gradient-primary flex items-center justify-center shadow-[0_0_15px_rgba(255,107,0,0.4)]">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
                </div>
                <span class="text-xl font-bold"><%= user.shopName %></span>
            </div>
            <div class="flex items-center gap-6">
                <a href="/vendor/dashboard" class="text-gray-400 hover:text-white transition">Live Orders</a>
                <a href="/vendor/menu" class="text-orange-500 font-medium">Menu & QR</a>
                <a href="/vendor/settings" class="text-gray-400 hover:text-white transition">Settings</a>
                <a href="/vendor/reports" class="text-gray-400 hover:text-white transition">Reports</a>
                <a href="/logout" class="bg-white/10 hover:bg-white/20 px-4 py-2 rounded-lg text-sm font-medium transition">Logout</a>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <main class="max-w-7xl mx-auto px-6 py-8">
        <h1 class="text-3xl font-bold mb-8">Manage Menu & Tables</h1>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-10">
            
            <!-- LEFT COLUMN: MENU ITEMS -->
            <div class="space-y-6">
                <!-- Add Item Form -->
                <div class="bg-[#121624] border border-white/5 rounded-2xl p-6 shadow-lg">
    <h2 class="text-xl font-semibold mb-4 text-orange-400">Add New Menu Item</h2>
    <!-- IMPORTANT: Added enctype for image uploads -->
    <form action="/vendor/menu/add" method="POST" enctype="multipart/form-data" class="space-y-4">
        <div class="grid grid-cols-3 gap-4">
    <div>
        <label class="block text-xs text-gray-400 mb-1">Item Name</label>
        <input type="text" name="name" required class="w-full bg-[#0B0E16] border border-white/10 rounded-xl px-4 py-2 text-white focus:border-orange-500 outline-none">
    </div>
    <div>
        <label class="block text-xs text-gray-400 mb-1">Price (₹)</label>
        <input type="number" name="price" required class="w-full bg-[#0B0E16] border border-white/10 rounded-xl px-4 py-2 text-white focus:border-orange-500 outline-none">
    </div>
    <div>
        <label class="block text-xs text-gray-400 mb-1">Offer Price (Optional)</label>
        <input type="number" name="offerPrice" class="w-full bg-[#0B0E16] border border-white/10 rounded-xl px-4 py-2 text-white focus:border-orange-500 outline-none" placeholder="e.g. 15">
    </div>
</div>
        <div class="grid grid-cols-2 gap-4">
            <div>
                <label class="block text-xs text-gray-400 mb-1">Category</label>
                <select name="category" class="w-full bg-[#0B0E16] border border-white/10 rounded-xl px-4 py-2 text-white focus:border-orange-500 outline-none">
                    <option value="Beverages">Beverages</option>
                    <option value="Snacks">Snacks</option>
                    <option value="Meals">Meals</option>
                </select>
            </div>
            <div>
                <label class="block text-xs text-gray-400 mb-1">Food Image</label>
                <input type="file" name="image" accept="image/*" class="w-full bg-[#0B0E16] border border-white/10 rounded-xl px-4 py-1.5 text-white text-sm focus:border-orange-500 outline-none">
            </div>
        </div>
        <button type="submit" class="w-full bg-white/10 hover:bg-white/20 text-white font-medium rounded-xl py-2.5 transition">Add Item</button>
    </form>
</div>

                <!-- List of Items -->
                <div class="bg-[#121624] border border-white/5 rounded-2xl p-6 shadow-lg">
    <h2 class="text-xl font-semibold mb-4 text-white">Your Menu (<%= items.length %>)</h2>
    <% if (items.length === 0) { %>
        <p class="text-gray-500 text-sm">No items added yet.</p>
    <% } else { %>
        <div class="space-y-3 max-h-96 overflow-y-auto pr-2">
            <% items.forEach(item => { %>
    <div class="bg-[#0B0E16] border border-white/5 p-3 rounded-xl flex flex-col gap-3">
        <div class="flex justify-between items-center">
            <div class="flex items-center gap-3">
                <img src="<%= item.image %>" class="w-12 h-12 rounded-lg object-cover">
                <div>
                    <h4 class="font-semibold text-white text-sm"><%= item.name %></h4>
                    <p class="text-xs text-gray-500"><%= item.category %></p>
                </div>
            </div>
            <div class="flex items-center gap-4">
                <div class="text-right">
                    <% if(item.offerPrice) { %>
                        <span class="text-gray-500 line-through text-xs mr-1">₹<%= item.price %></span>
                        <span class="text-orange-400 font-bold text-lg">₹<%= item.offerPrice %></span>
                    <% } else { %>
                        <span class="text-orange-400 font-bold text-lg">₹<%= item.price %></span>
                    <% } %>
                </div>
                <!-- Toggle Edit Form JS -->
                <button onclick="document.getElementById('edit-<%= item._id %>').classList.toggle('hidden')" class="bg-blue-500/10 text-blue-400 p-2 rounded-lg">✏️</button>
                <form action="/vendor/menu/delete/<%= item._id %>" method="POST" onsubmit="return confirm('Delete this item?');">
                    <button type="submit" class="bg-red-500/10 text-red-500 p-2 rounded-lg">🗑️</button>
                </form>
            </div>
        </div>

        <!-- Hidden Edit Form -->
        <form id="edit-<%= item._id %>" action="/vendor/menu/edit/<%= item._id %>" method="POST" enctype="multipart/form-data" class="hidden bg-[#121624] p-4 rounded-xl border border-white/10 mt-2 space-y-3">
            <div class="grid grid-cols-3 gap-3">
                <input type="text" name="name" value="<%= item.name %>" class="bg-[#0B0E16] rounded-lg px-3 py-1.5 text-sm text-white" placeholder="Name">
                <input type="number" name="price" value="<%= item.price %>" class="bg-[#0B0E16] rounded-lg px-3 py-1.5 text-sm text-white" placeholder="Price">
                <input type="number" name="offerPrice" value="<%= item.offerPrice || '' %>" class="bg-[#0B0E16] rounded-lg px-3 py-1.5 text-sm text-white" placeholder="Offer Price">
            </div>
            <div class="grid grid-cols-2 gap-3">
                <select name="category" class="bg-[#0B0E16] rounded-lg px-3 py-1.5 text-sm text-white">
                    <option value="Beverages" <%= item.category == 'Beverages' ? 'selected' : '' %>>Beverages</option>
                    <option value="Snacks" <%= item.category == 'Snacks' ? 'selected' : '' %>>Snacks</option>
                    <option value="Meals" <%= item.category == 'Meals' ? 'selected' : '' %>>Meals</option>
                </select>
                <input type="file" name="image" accept="image/*" class="bg-[#0B0E16] rounded-lg px-3 py-1 text-xs text-white">
            </div>
            <button type="submit" class="w-full bg-blue-500 hover:bg-blue-600 text-white rounded-lg py-1.5 text-sm font-bold">Save Changes</button>
        </form>
    </div>
<% }) %>
    <% } %>
</div>

            <!-- RIGHT COLUMN: QR CODES & TABLES -->
            <div class="space-y-6">
                <!-- Add Table Form -->
                <div class="bg-[#121624] border border-white/5 rounded-2xl p-6 shadow-lg">
                    <h2 class="text-xl font-semibold mb-4 text-emerald-400">Add Table / Generate QR</h2>
                    <form action="/vendor/table/add" method="POST" class="flex gap-4 items-end">
                        <div class="flex-1">
                            <label class="block text-xs text-gray-400 mb-1">Table Number</label>
                            <input type="number" name="tableNumber" required min="1" class="w-full bg-[#0B0E16] border border-white/10 rounded-xl px-4 py-2.5 text-white focus:border-emerald-500 outline-none" placeholder="e.g. 1">
                        </div>
                        <button type="submit" class="bg-emerald-500/20 text-emerald-400 hover:bg-emerald-500/30 border border-emerald-500/30 font-medium rounded-xl px-6 py-2.5 transition">
                            Generate QR
                        </button>
                    </form>
                </div>

                <!-- List of Tables & QR Codes -->
                <div class="bg-[#121624] border border-white/5 rounded-2xl p-6 shadow-lg">
                    <h2 class="text-xl font-semibold mb-4 text-white">Your Tables (<%= tables.length %>)</h2>
                    <% if (tables.length === 0) { %>
                        <p class="text-gray-500 text-sm">No tables added yet. Generate a QR code to start receiving orders!</p>
                    <% } else { %>
                        <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
                            <% tables.forEach(table => { %>
                                <div class="bg-[#0B0E16] border border-white/5 p-4 rounded-xl flex flex-col items-center text-center group">
                                    <h4 class="font-bold text-white mb-2">Table <%= table.tableNumber %></h4>
                                    <!-- Display the base64 QR Code image -->
                                    <div class="bg-white p-2 rounded-lg mb-3">
                                        <img src="<%= table.qrCodeUrl %>" alt="QR Code" class="w-full h-auto rounded">
                                    </div>
                                    <!-- Print/Download Button -->
                                    <a href="<%= table.qrCodeUrl %>" download="Table_<%= table.tableNumber %>_QR.png" class="text-xs bg-white/10 hover:bg-white/20 py-1.5 px-3 rounded-lg text-gray-300 w-full transition">Download</a>
                                </div>
                            <% }) %>
                        </div>
                    <% } %>
                </div>
            </div>

        </div>
    </main>
</body>
</html>