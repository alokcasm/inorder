<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Settings - inOrder</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #07090F; color: #ffffff; }
        .bg-gradient-primary { background-image: linear-gradient(to right, #FF6B00, #FF3D3D); }
        /* Toggle Switch CSS */
        .toggle-checkbox:checked { right: 0; border-color: #10B981; }
        .toggle-checkbox:checked + .toggle-label { background-color: #10B981; }
    </style>
</head>
<body class="antialiased">

    <!-- Navbar -->
    <nav class="bg-[#0B0E16] border-b border-white/[0.05] sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center">
            <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-lg bg-gradient-primary flex items-center justify-center shadow-[0_0_15px_rgba(255,107,0,0.4)]">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
                </div>
                <span class="text-xl font-bold"><%= user.shopName %></span>
            </div>
            <div class="flex items-center gap-6">
                <a href="/vendor/dashboard" class="text-gray-400 hover:text-white transition">Live Orders</a>
                <a href="/vendor/menu" class="text-gray-400 hover:text-white transition">Menu</a>
                <a href="/vendor/settings" class="text-orange-500 font-medium">Settings</a>
                <a href="/logout" class="bg-white/10 hover:bg-white/20 px-4 py-2 rounded-lg text-sm font-medium transition">Logout</a>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <main class="max-w-2xl mx-auto px-6 py-12">
        <h1 class="text-3xl font-bold mb-8">Shop Settings</h1>

        <div class="bg-[#121624] border border-white/5 rounded-3xl p-8 shadow-2xl relative overflow-hidden">
            <form action="/vendor/settings/update" method="POST" class="space-y-8">
                
                <!-- Restaurant Status Toggle -->
                <div class="flex items-center justify-between border-b border-white/5 pb-6">
                    <div>
                        <h3 class="text-lg font-bold text-white">Accepting Orders</h3>
                        <p class="text-sm text-gray-400 mt-1">Turn off if your kitchen is overloaded or closed.</p>
                    </div>
                    
                    <div class="relative inline-block w-12 mr-2 align-middle select-none transition duration-200 ease-in">
                        <input type="checkbox" name="isOpen" id="toggle" class="toggle-checkbox absolute block w-6 h-6 rounded-full bg-white border-4 appearance-none cursor-pointer transition-all duration-300" <%= vendor.isOpen ? 'checked' : '' %>/>
                        <label for="toggle" class="toggle-label block overflow-hidden h-6 rounded-full bg-gray-600 cursor-pointer transition-colors duration-300"></label>
                    </div>
                </div>

                <!-- UPI ID Setup -->
                <div>
                    <h3 class="text-lg font-bold text-white mb-2">Payment Details</h3>
                    <p class="text-sm text-gray-400 mb-4">Enter your UPI ID to accept digital payments from customers.</p>
                    
                    <label class="block text-xs text-gray-400 mb-1">Business UPI ID</label>
                    <input type="text" name="upiId" value="<%= vendor.upiId %>" class="w-full bg-[#0B0E16] border border-white/10 rounded-xl px-4 py-3 text-white focus:border-orange-500 outline-none" placeholder="e.g. 9876543210@paytm">
                </div>

                <button type="submit" class="w-full bg-gradient-primary text-white font-bold rounded-xl py-3.5 shadow-lg hover:-translate-y-0.5 transition-all">
                    Save Settings
                </button>
            </form>
        </div>
    </main>

</body>
</html>