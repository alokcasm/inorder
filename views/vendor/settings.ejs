<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Settings - inOrder</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #07090F; color: #ffffff; }
        .bg-gradient-primary { background-image: linear-gradient(to right, #FF6B00, #FF3D3D); }
        /* Toggle Switch CSS */
        .toggle-checkbox:checked { right: 0; border-color: #10B981; }
        .toggle-checkbox:checked + .toggle-label { background-color: #10B981; }
    </style>
</head>
<body class="antialiased">

    <!-- Navbar -->
    <nav class="bg-[#0B0E16] border-b border-white/[0.05] sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center">
            <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-lg bg-gradient-primary flex items-center justify-center shadow-[0_0_15px_rgba(255,107,0,0.4)]">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
                </div>
                <span class="text-xl font-bold"><%= user.shopName %></span>
            </div>
            <div class="flex items-center gap-6">
                <a href="/vendor/dashboard" class="text-gray-400 hover:text-white transition">Live Orders</a>
                <a href="/vendor/menu" class="text-gray-400 hover:text-white transition">Menu</a>
                <a href="/vendor/settings" class="text-orange-500 font-medium">Settings</a>
                <a href="/logout" class="bg-white/10 hover:bg-white/20 px-4 py-2 rounded-lg text-sm font-medium transition">Logout</a>
            </div>
        </div>
    </nav>
    <!--Coupon-->

     <h2 class="text-2xl font-bold mb-4 mt-12">Discount Coupons</h2>
        <div class="bg-[#121624] border border-white/5 rounded-3xl p-8 shadow-2xl">
            <form action="/vendor/coupon/add" method="POST" class="flex gap-4 items-end mb-6">
                <div class="flex-1">
                    <label class="block text-xs text-gray-400 mb-1">Coupon Code</label>
                    <input type="text" name="code" required class="w-full bg-[#0B0E16] rounded-xl px-4 py-3 text-white uppercase outline-none focus:border-orange-500 border border-white/10" placeholder="e.g. WELCOME50">
                </div>
                <div class="w-1/4">
                    <label class="block text-xs text-gray-400 mb-1">Type</label>
                    <select name="discountType" class="w-full bg-[#0B0E16] rounded-xl px-4 py-3 text-white outline-none border border-white/10">
                        <option value="FLAT">Flat ₹ Off</option>
                        <option value="PERCENTAGE">% Off</option>
                    </select>
                </div>
                <div class="w-1/4">
                    <label class="block text-xs text-gray-400 mb-1">Value</label>
                    <input type="number" name="discountValue" required class="w-full bg-[#0B0E16] rounded-xl px-4 py-3 text-white outline-none border border-white/10" placeholder="50">
                </div>
                <button type="submit" class="bg-emerald-500 hover:bg-emerald-600 text-white font-bold py-3 px-6 rounded-xl transition">Add</button>
            </form>

            <!-- List Coupons -->
            <div class="space-y-3">
                <% coupons.forEach(coupon => { %>
                    <div class="bg-[#0B0E16] border border-white/5 p-4 rounded-xl flex justify-between items-center">
                        <div>
                            <span class="bg-orange-500/20 text-orange-500 font-bold px-3 py-1 rounded text-sm border border-orange-500/30"><%= coupon.code %></span>
                            <span class="text-gray-400 text-sm ml-3"><%= coupon.discountType === 'FLAT' ? '₹' + coupon.discountValue + ' OFF' : coupon.discountValue + '% OFF' %></span>
                        </div>
                        <form action="/vendor/coupon/delete/<%= coupon._id %>" method="POST">
                            <button type="submit" class="text-red-500 bg-red-500/10 hover:bg-red-500/20 p-2 rounded-lg">🗑️</button>
                        </form>
                    </div>
                <% }) %>
            </div>
        </div>
        
    <!-- Main Content -->
    <main class="max-w-2xl mx-auto px-6 py-12">
        <h1 class="text-3xl font-bold mb-8">Shop Settings</h1>

        <div class="bg-[#121624] border border-white/5 rounded-3xl p-8 shadow-2xl relative overflow-hidden">

             <!-- Approval Status Banner -->
            <% if(vendor.isApproved) { %>
                <div class="bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 p-4 rounded-xl mb-6 flex items-center gap-3">
                    <span class="text-xl">✅</span>
                    <div>
                        <p class="font-bold">Account Verified & Active</p>
                        <p class="text-xs text-emerald-400/80">Your restaurant is live and can accept orders.</p>
                    </div>
                </div>
            <% } else { %>
                <div class="bg-red-500/10 border border-red-500/20 text-red-400 p-4 rounded-xl mb-6 flex items-center gap-3">
                    <span class="text-xl">⚠️</span>
                    <div>
                        <p class="font-bold">Account Pending Approval</p>
                        <p class="text-xs text-red-400/80">Upload your Aadhar & PAN below. Customers cannot place orders until Admin approves your account.</p>
                    </div>
                </div>
            <% } %>

            <!-- Add enctype for file uploads -->
            <form action="/vendor/settings/update" method="POST" enctype="multipart/form-data" class="space-y-8">
                
                <div class="flex items-center justify-between border-b border-white/5 pb-6">
                    <div>
                        <h3 class="text-lg font-bold text-white">Accepting Orders</h3>
                        <p class="text-sm text-gray-400 mt-1">Turn off if your kitchen is overloaded or closed.</p>
                    </div>
                    <div class="relative inline-block w-12 mr-2 align-middle select-none transition duration-200 ease-in">
                        <!-- Toggle is disabled visually if not approved -->
                        <input type="checkbox" name="isOpen" id="toggle" class="toggle-checkbox absolute block w-6 h-6 rounded-full bg-white border-4 appearance-none cursor-pointer transition-all duration-300" <%= vendor.isOpen ? 'checked' : '' %> <%= !vendor.isApproved ? 'disabled' : '' %>/>
                        <label for="toggle" class="toggle-label block overflow-hidden h-6 rounded-full bg-gray-600 cursor-pointer transition-colors duration-300"></label>
                    </div>
                </div>

                <div>
                    <h3 class="text-lg font-bold text-white mb-2">Payment Details</h3>
                    <input type="text" name="upiId" value="<%= vendor.upiId %>" class="w-full bg-[#0B0E16] border border-white/10 rounded-xl px-4 py-3 text-white focus:border-orange-500 outline-none" placeholder="e.g. 9876543210@paytm">
                </div>

                <!-- KYC Document Uploads -->
                <div class="border-t border-white/5 pt-6">
                    <h3 class="text-lg font-bold text-white mb-4">KYC Documents</h3>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        
                        <!-- Aadhar -->
                        <div class="bg-[#0B0E16] p-4 rounded-xl border border-white/5">
                            <label class="block text-sm font-bold text-gray-300 mb-2">Aadhar Card</label>
                            <% if(vendor.aadharImage) { %>
                                <p class="text-xs text-emerald-400 mb-2">✅ Uploaded</p>
                            <% } %>
                            <input type="file" name="aadhar" accept="image/*" class="w-full text-xs text-gray-400 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-xs file:font-semibold file:bg-white/10 file:text-white hover:file:bg-white/20">
                        </div>

                        <!-- PAN -->
                        <div class="bg-[#0B0E16] p-4 rounded-xl border border-white/5">
                            <label class="block text-sm font-bold text-gray-300 mb-2">PAN Card</label>
                            <% if(vendor.panImage) { %>
                                <p class="text-xs text-emerald-400 mb-2">✅ Uploaded</p>
                            <% } %>
                            <input type="file" name="pan" accept="image/*" class="w-full text-xs text-gray-400 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-xs file:font-semibold file:bg-white/10 file:text-white hover:file:bg-white/20">
                        </div>
                    </div>
                </div>

                <button type="submit" class="w-full bg-gradient-primary text-white font-bold rounded-xl py-3.5 shadow-lg hover:-translate-y-0.5 transition-all">
                    Save Settings & Submit KYC
                </button>
            </form>

        </div>
    </main>

</body>
</html>