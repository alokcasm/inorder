<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Settings - inOrder</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #07090F; color: #ffffff; overflow-x: hidden; }
        .bg-gradient-primary { background-image: linear-gradient(135deg, #FF6B00, #FF3D3D); }
        
        /* Smooth Toggle Switch CSS */
        .toggle-checkbox:checked { right: 0; border-color: #10B981; }
        .toggle-checkbox:checked + .toggle-label { background-color: #10B981; }
    </style>
</head>
<body class="antialiased selection:bg-orange-500/30">

    <!-- ========================================= -->
    <!-- RESPONSIVE NAVBAR                         -->
    <!-- ========================================= -->
    <nav class="bg-[#0B0E16]/90 backdrop-blur-xl border-b border-white/[0.05] sticky top-0 z-40">
        <div class="max-w-7xl mx-auto px-5 sm:px-6 py-4 flex justify-between items-center">
            
            <!-- Logo -->
            <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-lg bg-gradient-primary flex items-center justify-center shadow-[0_0_15px_rgba(255,107,0,0.4)]">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
                </div>
                <span class="text-xl font-bold tracking-tight"><%= user.shopName %></span>
            </div>
            
            <!-- Desktop Links (Hidden on Mobile) -->
            <div class="hidden lg:flex items-center gap-6">
                <a href="/vendor/dashboard" class="text-gray-400 hover:text-white font-medium transition">Live Orders</a>
                <a href="/vendor/menu" class="text-gray-400 hover:text-white font-medium transition">Menu & QR</a>
                <a href="/vendor/reports" class="text-gray-400 hover:text-white font-medium transition">Reports</a>
                <a href="/vendor/settings" class="text-orange-500 font-medium">Settings</a>
                <a href="/logout" class="bg-white/10 hover:bg-white/20 px-4 py-2 rounded-xl text-sm font-bold transition">Logout</a>
            </div>

            <!-- Mobile Hamburger Button -->
            <button onclick="openSidebar()" class="lg:hidden text-gray-300 hover:text-white p-1 focus:outline-none">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
            </button>
        </div>
    </nav>

    <!-- ========================================= -->
    <!-- MOBILE SIDEBAR (Off-canvas)               -->
    <!-- ========================================= -->
    
    <!-- Dark Overlay Backdrop -->
    <div id="sidebarOverlay" onclick="closeSidebar()" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-50 hidden opacity-0 transition-opacity duration-300"></div>

    <!-- Sliding Sidebar Menu -->
    <div id="mobileSidebar" class="fixed top-0 right-0 w-64 h-full bg-[#0B0E16] border-l border-white/5 z-[60] transform translate-x-full transition-transform duration-300 ease-in-out flex flex-col shadow-2xl">
        
        <!-- Sidebar Header -->
        <div class="px-6 py-5 border-b border-white/5 flex justify-between items-center bg-[#121624]/50">
            <span class="font-extrabold text-white tracking-widest uppercase text-sm">Menu</span>
            <button onclick="closeSidebar()" class="text-gray-400 hover:text-white p-1 bg-white/5 rounded-full">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
            </button>
        </div>

        <!-- Sidebar Links -->
        <div class="flex flex-col p-4 space-y-2 flex-1">
            <a href="/vendor/dashboard" class="flex items-center gap-3 px-4 py-3 rounded-xl text-gray-400 hover:text-white hover:bg-white/5 font-semibold transition-colors">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="3" y1="9" x2="21" y2="9"></line><line x1="9" y1="21" x2="9" y2="9"></line></svg>
                Live Orders
            </a>
            <a href="/vendor/menu" class="flex items-center gap-3 px-4 py-3 rounded-xl text-gray-400 hover:text-white hover:bg-white/5 font-semibold transition-colors">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
                Menu & QR
            </a>
            <a href="/vendor/reports" class="flex items-center gap-3 px-4 py-3 rounded-xl text-gray-400 hover:text-white hover:bg-white/5 font-semibold transition-colors">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="20" x2="18" y2="10"></line><line x1="12" y1="20" x2="12" y2="4"></line><line x1="6" y1="20" x2="6" y2="14"></line></svg>
                Reports
            </a>
            
            <!-- Active State for Settings -->
            <a href="/vendor/settings" class="flex items-center gap-3 px-4 py-3 rounded-xl bg-orange-500/10 text-orange-500 border border-orange-500/20 font-bold transition-colors">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"></circle><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path></svg>
                Settings
            </a>
        </div>

        <!-- Sidebar Footer -->
        <div class="p-5 border-t border-white/5">
            <a href="/logout" class="flex justify-center items-center gap-2 w-full bg-red-500/10 hover:bg-red-500/20 text-red-500 font-bold py-3.5 rounded-xl border border-red-500/20 transition-colors">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg>
                Sign Out
            </a>
        </div>
    </div>


    <!-- Main Content Area -->
    <main class="max-w-4xl mx-auto px-5 sm:px-6 py-8 sm:py-12 space-y-8">
        
        <!-- Header -->
        <div>
            <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight">Shop Settings</h1>
            <p class="text-gray-400 text-sm mt-1">Manage your restaurant status, KYC, and discount coupons.</p>
        </div>

        <!-- ========================================= -->
        <!-- SECTION 1: KYC & GENERAL SETTINGS         -->
        <!-- ========================================= -->
        <div class="bg-[#121624] border border-white/5 rounded-[2rem] p-6 sm:p-10 shadow-2xl relative overflow-hidden">
            <!-- Orange top accent line -->
            <div class="absolute top-0 left-0 w-full h-1 bg-gradient-primary"></div>

            <!-- Approval Status Banner -->
            <% if(vendor.isApproved) { %>
                <div class="bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 p-4 rounded-2xl mb-8 flex items-center gap-4 shadow-sm">
                    <div class="text-2xl drop-shadow-[0_0_10px_rgba(16,185,129,0.8)]">✅</div>
                    <div>
                        <p class="font-bold text-sm sm:text-base tracking-wide uppercase">Account Verified & Active</p>
                        <p class="text-xs text-emerald-400/80 mt-0.5">Your restaurant is live and ready to accept orders.</p>
                    </div>
                </div>
            <% } else { %>
                <div class="bg-red-500/10 border border-red-500/20 text-red-400 p-4 rounded-2xl mb-8 flex items-center gap-4 shadow-sm">
                    <div class="text-2xl drop-shadow-[0_0_10px_rgba(239,68,68,0.8)]">⚠️</div>
                    <div>
                        <p class="font-bold text-sm sm:text-base tracking-wide uppercase">Account Pending Approval</p>
                        <p class="text-xs text-red-400/80 mt-0.5">Upload your Aadhar & PAN. Customers cannot place orders until Admin approves your account.</p>
                    </div>
                </div>
            <% } %>

            <form action="/vendor/settings/update" method="POST" enctype="multipart/form-data" class="space-y-8">
                
                <!-- Restaurant ON/OFF Toggle -->
                <div class="flex items-center justify-between border-b border-white/5 pb-6">
                    <div class="pr-4">
                        <h3 class="text-lg font-bold text-white">Accepting Orders</h3>
                        <p class="text-xs sm:text-sm text-gray-400 mt-1 leading-relaxed">Turn off if your kitchen is overloaded or closed. Customers will see a "Kitchen Closed" message.</p>
                    </div>
                    <div class="relative inline-block w-12 shrink-0 align-middle select-none transition duration-200 ease-in">
                        <input type="checkbox" name="isOpen" id="toggle" class="toggle-checkbox absolute block w-6 h-6 rounded-full bg-white border-4 appearance-none cursor-pointer transition-all duration-300" <%= vendor.isOpen ? 'checked' : '' %> <%= !vendor.isApproved ? 'disabled' : '' %>/>
                        <label for="toggle" class="toggle-label block overflow-hidden h-6 rounded-full bg-gray-600 cursor-pointer transition-colors duration-300 shadow-inner"></label>
                    </div>
                </div>

                <!-- UPI Details -->
                <div>
                    <h3 class="text-lg font-bold text-white mb-1">Payment Details</h3>
                    <p class="text-xs sm:text-sm text-gray-400 mb-4">Enter your UPI ID to accept digital payments via Razorpay.</p>
                    
                    <label class="block text-[11px] font-bold text-gray-400 mb-1.5 uppercase tracking-wider">Business UPI ID</label>
                    <input type="text" name="upiId" value="<%= vendor.upiId %>" class="w-full bg-[#0B0E16] border border-white/10 rounded-xl px-4 py-3 text-white text-sm focus:border-orange-500 focus:ring-1 focus:ring-orange-500 outline-none transition-shadow shadow-inner" placeholder="e.g. 9876543210@paytm">
                </div>

                <!-- KYC Documents -->
                <div class="border-t border-white/5 pt-6">
                    <h3 class="text-lg font-bold text-white mb-4">KYC Documents</h3>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 sm:gap-6">
                        
                        <!-- Aadhar Card -->
                        <div class="bg-[#0B0E16] p-4 sm:p-5 rounded-2xl border border-white/5 shadow-inner">
                            <div class="flex justify-between items-start mb-3">
                                <label class="block text-sm font-bold text-gray-300">Aadhar Card</label>
                                <% if(vendor.aadharImage) { %>
                                    <span class="bg-emerald-500/10 text-emerald-400 text-[10px] font-bold px-2 py-0.5 rounded border border-emerald-500/20 uppercase tracking-wider">Uploaded</span>
                                <% } else { %>
                                    <span class="bg-red-500/10 text-red-400 text-[10px] font-bold px-2 py-0.5 rounded border border-red-500/20 uppercase tracking-wider">Missing</span>
                                <% } %>
                            </div>
                            <input type="file" name="aadhar" accept="image/*" class="w-full text-xs text-gray-400 file:mr-4 file:py-1.5 file:px-4 file:rounded-lg file:border-0 file:text-xs file:font-bold file:bg-white/10 file:text-white hover:file:bg-white/20 transition cursor-pointer outline-none">
                        </div>

                        <!-- PAN Card -->
                        <div class="bg-[#0B0E16] p-4 sm:p-5 rounded-2xl border border-white/5 shadow-inner">
                            <div class="flex justify-between items-start mb-3">
                                <label class="block text-sm font-bold text-gray-300">PAN Card</label>
                                <% if(vendor.panImage) { %>
                                    <span class="bg-emerald-500/10 text-emerald-400 text-[10px] font-bold px-2 py-0.5 rounded border border-emerald-500/20 uppercase tracking-wider">Uploaded</span>
                                <% } else { %>
                                    <span class="bg-red-500/10 text-red-400 text-[10px] font-bold px-2 py-0.5 rounded border border-red-500/20 uppercase tracking-wider">Missing</span>
                                <% } %>
                            </div>
                            <input type="file" name="pan" accept="image/*" class="w-full text-xs text-gray-400 file:mr-4 file:py-1.5 file:px-4 file:rounded-lg file:border-0 file:text-xs file:font-bold file:bg-white/10 file:text-white hover:file:bg-white/20 transition cursor-pointer outline-none">
                        </div>
                    </div>
                </div>

                <button type="submit" class="w-full bg-gradient-primary text-white font-bold rounded-xl py-4 shadow-[0_5px_15px_rgba(255,107,0,0.3)] hover:-translate-y-0.5 active:scale-95 transition-all text-sm sm:text-base">
                    Save Settings & Submit KYC
                </button>
            </form>
        </div>


        <!-- ========================================= -->
        <!-- SECTION 2: DISCOUNT COUPONS               -->
        <!-- ========================================= -->
        <div class="bg-[#121624] border border-white/5 rounded-[2rem] p-6 sm:p-10 shadow-2xl relative overflow-hidden">
            <!-- Blue top accent line -->
            <div class="absolute top-0 left-0 w-full h-1 bg-blue-500"></div>

            <div class="mb-6">
                <h2 class="text-2xl font-bold text-white flex items-center gap-2">
                    <span class="text-blue-400">🎟️</span> Discount Coupons
                </h2>
                <p class="text-xs sm:text-sm text-gray-400 mt-1">Create promo codes to attract more customers.</p>
            </div>
            
            <!-- Add Coupon Form -->
            <form action="/vendor/coupon/add" method="POST" class="flex flex-col sm:flex-row gap-4 items-end mb-8 bg-[#0B0E16] p-4 sm:p-5 rounded-2xl border border-white/5 shadow-inner">
                <div class="w-full sm:flex-1">
                    <label class="block text-[11px] font-bold text-gray-400 mb-1.5 uppercase tracking-wider">Coupon Code</label>
                    <input type="text" name="code" required class="w-full bg-[#121624] rounded-xl px-4 py-3 text-white uppercase outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 border border-white/5 transition-all text-sm" placeholder="e.g. WELCOME50">
                </div>
                <div class="w-full sm:w-1/4">
                    <label class="block text-[11px] font-bold text-gray-400 mb-1.5 uppercase tracking-wider">Type</label>
                    <select name="discountType" class="w-full bg-[#121624] rounded-xl px-4 py-3 text-white outline-none border border-white/5 focus:border-blue-500 text-sm appearance-none cursor-pointer">
                        <option value="FLAT">Flat ₹ Off</option>
                        <option value="PERCENTAGE">% Off</option>
                    </select>
                </div>
                <div class="w-full sm:w-1/4">
                    <label class="block text-[11px] font-bold text-gray-400 mb-1.5 uppercase tracking-wider">Value</label>
                    <input type="number" name="discountValue" required class="w-full bg-[#121624] rounded-xl px-4 py-3 text-white outline-none border border-white/5 focus:border-blue-500 text-sm" placeholder="e.g. 50">
                </div>
                <button type="submit" class="w-full sm:w-auto bg-blue-500 hover:bg-blue-600 text-white font-bold py-3 px-8 rounded-xl shadow-[0_5px_15px_rgba(59,130,246,0.3)] transition active:scale-95 text-sm sm:text-base">
                    Add
                </button>
            </form>

            <!-- Active Coupons List -->
            <div class="space-y-3">
                <h3 class="text-sm font-bold text-gray-300 mb-3 uppercase tracking-wider">Active Promo Codes</h3>
                
                <% if(coupons.length === 0) { %>
                    <p class="text-gray-500 text-sm italic">You don't have any active coupons right now.</p>
                <% } else { %>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <% coupons.forEach(coupon => { %>
                            <div class="bg-[#0B0E16] border border-white/5 p-4 rounded-xl flex justify-between items-center group hover:border-white/10 transition">
                                <div>
                                    <div class="flex items-center gap-2 mb-1">
                                        <span class="bg-blue-500/20 text-blue-400 font-extrabold px-2.5 py-0.5 rounded text-xs border border-blue-500/30 uppercase tracking-widest">
                                            <%= coupon.code %>
                                        </span>
                                    </div>
                                    <span class="text-gray-300 text-sm font-medium">
                                        <%= coupon.discountType === 'FLAT' ? 'Flat ₹' + coupon.discountValue + ' OFF' : coupon.discountValue + '% OFF your total bill' %>
                                    </span>
                                </div>
                                <form action="/vendor/coupon/delete/<%= coupon._id %>" method="POST" onsubmit="return confirm('Remove this coupon?');">
                                    <button type="submit" class="text-red-500 bg-red-500/10 hover:bg-red-500/20 p-2.5 rounded-lg transition active:scale-95">
                                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
                                    </button>
                                </form>
                            </div>
                        <% }) %>
                    </div>
                <% } %>
            </div>
        </div>

    </main>

    <!-- Script for Sidebar Toggle -->
    <script>
        const sidebar = document.getElementById('mobileSidebar');
        const overlay = document.getElementById('sidebarOverlay');

        function openSidebar() {
            overlay.classList.remove('hidden');
            setTimeout(() => overlay.classList.remove('opacity-0'), 10);
            sidebar.classList.remove('translate-x-full');
            document.body.style.overflow = 'hidden'; // Stop background scrolling
        }

        function closeSidebar() {
            sidebar.classList.add('translate-x-full');
            overlay.classList.add('opacity-0');
            setTimeout(() => overlay.classList.add('hidden'), 300);
            document.body.style.overflow = '';
        }
    </script>
</body>
</html>