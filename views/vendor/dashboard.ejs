<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Vendor Dashboard - inOrder</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #07090F; color: #ffffff; overflow-x: hidden; }
        .bg-gradient-primary { background-image: linear-gradient(135deg, #FF6B00, #FF3D3D); }
        
        /* FIX: Added the missing Toggle Switch CSS! */
        .toggle-checkbox:checked { right: 0; border-color: #10B981; }
        .toggle-checkbox:checked + .toggle-label { background-color: #10B981; }
        .toggle-checkbox { right: 20px; } /* Start position */
    </style>
</head>
<body class="antialiased selection:bg-orange-500/30">

    <!-- ========================================= -->
    <!-- RESPONSIVE NAVBAR                         -->
    <!-- ========================================= -->
    <nav class="bg-[#0B0E16]/90 backdrop-blur-xl border-b border-white/[0.05] sticky top-0 z-40">
        <div class="max-w-7xl mx-auto px-5 sm:px-6 py-4 flex justify-between items-center">
            
            <!-- Logo -->
            <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-lg bg-gradient-primary flex items-center justify-center shadow-[0_0_15px_rgba(255,107,0,0.4)]">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
                </div>
                <span class="text-xl font-bold tracking-tight"><%= user.shopName %></span>
            </div>
            
            <!-- Desktop Links -->
            <div class="hidden lg:flex items-center gap-6">
                <a href="/vendor/dashboard" class="text-orange-500 font-medium">Live Orders</a>
                <a href="/vendor/menu" class="text-gray-400 hover:text-white font-medium transition">Menu & QR</a>
                <a href="/vendor/reports" class="text-gray-400 hover:text-white font-medium transition">Reports</a>
                <a href="/vendor/settings" class="text-gray-400 hover:text-white font-medium transition">Settings</a>
                <a href="/logout" class="bg-white/10 hover:bg-white/20 px-4 py-2 rounded-xl text-sm font-bold transition">Logout</a>
            </div>

            <!-- Mobile Hamburger Button -->
            <button onclick="openSidebar()" class="lg:hidden text-gray-300 hover:text-white p-1 focus:outline-none">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
            </button>
        </div>
    </nav>

    <!-- ========================================= -->
    <!-- MOBILE SIDEBAR (Off-canvas)               -->
    <!-- ========================================= -->
    <div id="sidebarOverlay" onclick="closeSidebar()" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-50 hidden opacity-0 transition-opacity duration-300"></div>

    <div id="mobileSidebar" class="fixed top-0 right-0 w-64 h-full bg-[#0B0E16] border-l border-white/5 z-[60] transform translate-x-full transition-transform duration-300 ease-in-out flex flex-col shadow-2xl">
        <div class="px-6 py-5 border-b border-white/5 flex justify-between items-center bg-[#121624]/50">
            <span class="font-extrabold text-white tracking-widest uppercase text-sm">Menu</span>
            <button onclick="closeSidebar()" class="text-gray-400 hover:text-white p-1 bg-white/5 rounded-full">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
            </button>
        </div>

        <div class="flex flex-col p-4 space-y-2 flex-1">
            <!-- Active State for Dashboard -->
            <a href="/vendor/dashboard" class="flex items-center gap-3 px-4 py-3 rounded-xl bg-orange-500/10 text-orange-500 border border-orange-500/20 font-bold transition-colors">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="3" y1="9" x2="21" y2="9"></line><line x1="9" y1="21" x2="9" y2="9"></line></svg>
                Live Orders
            </a>
            <a href="/vendor/menu" class="flex items-center gap-3 px-4 py-3 rounded-xl text-gray-400 hover:text-white hover:bg-white/5 font-semibold transition-colors">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
                Menu & QR
            </a>
            <a href="/vendor/reports" class="flex items-center gap-3 px-4 py-3 rounded-xl text-gray-400 hover:text-white hover:bg-white/5 font-semibold transition-colors">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="20" x2="18" y2="10"></line><line x1="12" y1="20" x2="12" y2="4"></line><line x1="6" y1="20" x2="6" y2="14"></line></svg>
                Reports
            </a>
            <a href="/vendor/settings" class="flex items-center gap-3 px-4 py-3 rounded-xl text-gray-400 hover:text-white hover:bg-white/5 font-semibold transition-colors">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"></circle><path d="M19.4 15..."></path></svg>
                Settings
            </a>
        </div>

        <div class="p-5 border-t border-white/5">
            <a href="/logout" class="flex justify-center items-center gap-2 w-full bg-red-500/10 hover:bg-red-500/20 text-red-500 font-bold py-3.5 rounded-xl border border-red-500/20 transition-colors">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg>
                Sign Out
            </a>
        </div>
    </div>


    <!-- ========================================= -->
    <!-- MAIN CONTENT                              -->
    <!-- ========================================= -->
    <main class="max-w-7xl mx-auto px-5 sm:px-6 py-8">
        
        <!-- 🚨 NOT APPROVED WARNING BANNER 🚨 -->
        <% if (!vendor.isApproved) { %>
            <div class="bg-red-500/10 border border-red-500/30 rounded-[2rem] p-6 sm:p-8 mb-8 flex flex-col sm:flex-row items-start sm:items-center gap-4 sm:gap-6 shadow-lg">
                <div class="text-4xl">🛑</div>
                <div class="flex-1">
                    <h2 class="text-xl font-bold text-red-400 mb-1">Account Not Approved Yet</h2>
                    <p class="text-sm text-red-300 leading-relaxed">You can build your menu and generate QR codes, but <b>customers cannot place orders</b> until an Admin verifies your KYC documents.</p>
                </div>
                <a href="/vendor/settings" class="shrink-0 mt-2 sm:mt-0 bg-red-500 hover:bg-red-600 text-white font-bold py-3 px-6 rounded-xl text-sm transition shadow-lg">
                    Upload KYC
                </a>
            </div>
        <% } %>

        <!-- Header & Status Toggles -->
        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-end mb-8 gap-4">
            <div>
                <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight mb-2">Live Order Queue</h1>
                <p class="text-gray-400 text-sm">Manage incoming orders from your tables.</p>
            </div>
            
            <div class="flex flex-col sm:flex-row gap-3">
                <!-- Voice Alerts Toggle -->
                <div class="bg-[#121624] border border-white/5 px-4 py-2.5 rounded-xl text-sm font-bold flex items-center justify-between gap-3 shadow-sm">
                    <span class="text-gray-300">🔊 Voice Alerts</span>
                    <div class="relative inline-block w-10 h-5 align-middle select-none">
                        <!-- ID is important for JS memory -->
                        <input type="checkbox" id="voiceToggle" onchange="saveVoicePreference()" class="toggle-checkbox absolute block w-5 h-5 rounded-full bg-white border-4 border-gray-600 appearance-none cursor-pointer transition-all duration-300"/>
                        <label for="voiceToggle" class="toggle-label block overflow-hidden h-5 rounded-full bg-gray-600 cursor-pointer transition-colors duration-300"></label>
                    </div>
                </div>

                <!-- Restaurant Status -->
                <% if (vendor.isOpen && vendor.isApproved) { %>
                    <div class="bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 px-4 py-2.5 rounded-xl text-sm font-bold flex items-center gap-2.5 shadow-sm">
                        <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse shadow-[0_0_8px_rgba(16,185,129,0.8)]"></span>
                        Accepting Orders
                    </div>
                <% } else { %>
                    <div class="bg-yellow-500/10 text-yellow-500 border border-yellow-500/20 px-4 py-2.5 rounded-xl text-sm font-bold flex items-center gap-2.5 shadow-sm">
                        <span class="w-2 h-2 rounded-full bg-yellow-500"></span>
                        Currently Closed
                    </div>
                <% } %>
            </div>
        </div>
        
        <!-- Orders Grid -->
        <% if (orders.length === 0) { %>
            <div class="bg-[#121624] border border-white/5 rounded-[2rem] py-24 px-6 text-center shadow-lg">
                <div class="text-6xl mb-4 opacity-50">🍽️</div>
                <h3 class="text-xl font-bold text-white mb-2">No active orders right now</h3>
                <p class="text-gray-500 text-sm max-w-sm mx-auto">When customers scan your QR code and pay for their order, it will instantly appear here.</p>
            </div>
        <% } else { %>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                <% orders.forEach(order => { %>
                    <!-- Order Card -->
                    <div class="bg-[#121624] border border-white/[0.05] rounded-3xl p-6 shadow-[0_15px_40px_rgba(0,0,0,0.4)] flex flex-col relative overflow-hidden group">
                        
                        <!-- Glowing Status Bar -->
                        <% if(order.orderStatus === 'Pending') { %>
                            <div class="absolute top-0 left-0 w-full h-1.5 bg-orange-500 shadow-[0_0_20px_rgba(255,107,0,0.8)]"></div>
                        <% } else if(order.orderStatus === 'Preparing') { %>
                            <div class="absolute top-0 left-0 w-full h-1.5 bg-yellow-400 shadow-[0_0_20px_rgba(250,204,21,0.8)]"></div>
                        <% } else if(order.orderStatus === 'Ready') { %>
                            <div class="absolute top-0 left-0 w-full h-1.5 bg-emerald-500 shadow-[0_0_20px_rgba(16,185,129,0.8)]"></div>
                        <% } %>

                        <!-- Card Header -->
                        <div class="flex justify-between items-start mb-5 pt-1">
                            <div>
                                <h3 class="text-2xl font-black text-white tracking-tight">Table <%= order.tableNumber %></h3>
                                <p class="text-xs font-bold text-gray-500 mt-1 uppercase tracking-wider">ID: #<%= order._id.toString().slice(-5) %> • <span class="text-gray-300"><%= order.orderStatus %></span></p>
                            </div>
                            <div class="bg-emerald-500/10 text-emerald-400 text-[10px] font-extrabold px-2.5 py-1 rounded-md border border-emerald-500/20 uppercase tracking-widest shadow-sm">
                                <%= order.paymentStatus %>
                            </div>
                        </div>

                        <!-- Items List -->
                        <div class="flex-1 bg-[#0B0E16] rounded-2xl p-4 mb-5 space-y-2.5 border border-white/[0.02] shadow-inner">
                            <% order.items.forEach(item => { %>
                                <div class="flex justify-between text-sm items-start">
                                    <span class="text-gray-200 font-medium pr-2 leading-tight">
                                        <span class="text-orange-500 font-black mr-1"><%= item.quantity %>x</span> 
                                        <%= item.name %>
                                    </span>
                                </div>
                            <% }) %>
                        </div>

                        <!-- Action Footer -->
                        <div class="flex items-end justify-between mt-auto">
                            <div>
                                <span class="font-black text-xl text-white">₹<%= order.finalAmount || order.totalAmount %></span>
                                <% if (order.discountApplied && order.discountApplied > 0) { %>
                                    <span class="block text-[9px] text-emerald-400 font-extrabold uppercase tracking-widest mt-0.5">Coupon Used</span>
                                <% } %>
                            </div>
                            
                            <!-- Dynamic Forms based on status -->
                            <form action="/vendor/order/update" method="POST" class="flex gap-2">
                                <input type="hidden" name="orderId" value="<%= order._id %>">
                                
                                <% if(order.orderStatus === 'Pending') { %>
                                    <!-- CANCEL BUTTON -->
                                    <button type="submit" name="status" value="Cancelled" onclick="return confirm('Are you sure you want to cancel this order? You will need to manually refund the customer via Razorpay.');" class="bg-red-500/10 text-red-500 hover:bg-red-500/20 font-bold py-2.5 px-3 rounded-xl transition-transform active:scale-95 text-sm">
                                        ❌
                                    </button>
                                    <button type="submit" name="status" value="Preparing" class="bg-orange-500 hover:bg-orange-600 text-white font-bold py-2.5 px-5 rounded-xl shadow-[0_5px_15px_rgba(255,107,0,0.3)] transition-transform active:scale-95 text-sm tracking-wide">
                                        Prepare
                                    </button>
                                <% } else if(order.orderStatus === 'Preparing') { %>
                                    <!-- CANCEL BUTTON -->
                                    <button type="submit" name="status" value="Cancelled" onclick="return confirm('Are you sure you want to cancel this order? You will need to manually refund the customer via Razorpay.');" class="bg-red-500/10 text-red-500 hover:bg-red-500/20 font-bold py-2.5 px-3 rounded-xl transition-transform active:scale-95 text-sm">
                                        ❌
                                    </button>
                                    <button type="submit" name="status" value="Ready" class="bg-yellow-400 hover:bg-yellow-500 text-black font-extrabold py-2.5 px-5 rounded-xl shadow-[0_5px_15px_rgba(250,204,21,0.3)] transition-transform active:scale-95 text-sm tracking-wide">
                                        Mark Ready
                                    </button>
                                <% } else if(order.orderStatus === 'Ready') { %>
                                    <input type="hidden" name="status" value="Served">
                                    <button type="submit" class="w-full bg-emerald-500 hover:bg-emerald-600 text-white font-bold py-2.5 px-6 rounded-xl shadow-[0_5px_15px_rgba(16,185,129,0.3)] transition-transform active:scale-95 text-sm tracking-wide">
                                        Served
                                    </button>
                                <% } %>
                            </form>
                        </div>

                    </div>
                <% }) %>
            </div>
        <% } %>
    </main>

    <!-- Socket.io for Real-Time Updates -->
    <script src="/socket.io/socket.io.js"></script>
    <script>
        // --- VOICE TOGGLE MEMORY ---
        const voiceToggle = document.getElementById('voiceToggle');
        
        // Load preference on page load (Default is true)
        const savedPreference = localStorage.getItem('voiceAlertsEnabled');
        if (savedPreference !== null) {
            voiceToggle.checked = savedPreference === 'true';
        } else {
            voiceToggle.checked = true; // Default ON
        }

        // Save preference when clicked
        function saveVoicePreference() {
            localStorage.setItem('voiceAlertsEnabled', voiceToggle.checked);
        }

        // --- SOCKET LOGIC ---
        const socket = io();
        socket.emit('joinVendorRoom', '<%= user.id %>');
        
        socket.on('newOrder', (order) => {
            const voiceEnabled = voiceToggle.checked;

            if (voiceEnabled && 'speechSynthesis' in window) {
                const audio = new Audio('https://actions.google.com/sounds/v1/alarms/beep_short.ogg');
                audio.play();

                let announcement = `New order received on Table ${order.tableNumber}. `;
                order.items.forEach(item => { announcement += `${item.quantity} ${item.name}, `; });

                setTimeout(() => {
                    const utterance = new SpeechSynthesisUtterance(announcement);
                    utterance.rate = 0.9; 
                    utterance.onend = () => { window.location.reload(); };
                    window.speechSynthesis.speak(utterance);
                }, 500); 
            } else {
                const audio = new Audio('https://actions.google.com/sounds/v1/alarms/beep_short.ogg');
                audio.play();
                setTimeout(() => window.location.reload(), 1500);
            }
        });

        // --- SIDEBAR LOGIC ---
        const sidebar = document.getElementById('mobileSidebar');
        const overlay = document.getElementById('sidebarOverlay');

        function openSidebar() {
            overlay.classList.remove('hidden');
            setTimeout(() => overlay.classList.remove('opacity-0'), 10);
            sidebar.classList.remove('translate-x-full');
            document.body.style.overflow = 'hidden'; 
        }

        function closeSidebar() {
            sidebar.classList.add('translate-x-full');
            overlay.classList.add('opacity-0');
            setTimeout(() => overlay.classList.add('hidden'), 300);
            document.body.style.overflow = '';
        }
    </script>
</body>
</html>