<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reports - inOrder</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #07090F; color: #ffffff; }
        .bg-gradient-primary { background-image: linear-gradient(to right, #FF6B00, #FF3D3D); }
    </style>
</head>
<body class="antialiased">

    <!-- Navbar -->
    <nav class="bg-[#0B0E16] border-b border-white/[0.05] sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center">
            <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-lg bg-gradient-primary flex items-center justify-center shadow-[0_0_15px_rgba(255,107,0,0.4)]">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
                </div>
                <span class="text-xl font-bold"><%= user.shopName %></span>
            </div>
            <div class="flex items-center gap-6 hidden md:flex">
                <a href="/vendor/dashboard" class="text-gray-400 hover:text-white transition">Live Orders</a>
                <a href="/vendor/menu" class="text-gray-400 hover:text-white transition">Menu</a>
                <a href="/vendor/reports" class="text-orange-500 font-medium">Reports</a>
                <a href="/vendor/settings" class="text-gray-400 hover:text-white transition">Settings</a>
                <a href="/logout" class="bg-white/10 hover:bg-white/20 px-4 py-2 rounded-lg text-sm font-medium transition">Logout</a>
            </div>
        </div>
    </nav>

    <main class="max-w-7xl mx-auto px-6 py-8">
        <h1 class="text-3xl font-bold mb-8">Sales & Analytics</h1>

        <!-- Stat Cards -->
         <div class="grid grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6 mb-10">
            <!-- Today -->
            <div class="bg-[#121624] border border-white/5 rounded-2xl p-5 shadow-lg border-t-2 border-t-orange-500">
                <p class="text-gray-400 text-xs sm:text-sm font-medium mb-1">Today's Revenue</p>
                <h2 class="text-2xl sm:text-3xl font-bold text-white">₹<%= todaysRevenue %></h2>
                <p class="text-xs text-gray-500 mt-2"><%= todaysOrdersCount %> orders today</p>
            </div>
            <!-- Last 30 Days -->
            <div class="bg-[#121624] border border-white/5 rounded-2xl p-5 shadow-lg border-t-2 border-t-blue-500">
                <p class="text-gray-400 text-xs sm:text-sm font-medium mb-1">Last 30 Days</p>
                <h2 class="text-2xl sm:text-3xl font-bold text-white">₹<%= thirtyDaysRevenue %></h2>
                <p class="text-xs text-gray-500 mt-2"><%= thirtyDaysOrdersCount %> orders this month</p>
            </div>
            <!-- All Time -->
            <div class="bg-[#121624] border border-white/5 rounded-2xl p-5 shadow-lg border-t-2 border-t-emerald-500 col-span-2 lg:col-span-1">
                <p class="text-gray-400 text-xs sm:text-sm font-medium mb-1">All-Time Revenue</p>
                <h2 class="text-2xl sm:text-3xl font-bold text-white">₹<%= totalRevenue %></h2>
                <p class="text-xs text-gray-500 mt-2"><%= totalOrders %> lifetime orders</p>
            </div>
        </div>

        <!-- Order History & Ratings -->
        <h2 class="text-xl font-bold mb-4">Recent Completed Orders</h2>
        <div class="bg-[#121624] border border-white/5 rounded-2xl overflow-hidden shadow-lg">
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse min-w-[600px]">
                    <thead>
                        <tr class="bg-[#0B0E16] text-gray-400 text-sm border-b border-white/5">
                            <th class="p-4 font-medium">Order ID</th>
                            <th class="p-4 font-medium">Date & Time</th>
                            <th class="p-4 font-medium">Table</th>
                            <th class="p-4 font-medium">Amount</th>
                            <th class="p-4 font-medium">Rating & Feedback</th>
                        </tr>
                    </thead>
                    <tbody class="text-sm">
                        <% if(recentOrders.length === 0) { %>
                            <tr><td colspan="5" class="p-8 text-center text-gray-500">No completed orders yet.</td></tr>
                        <% } else { %>
                            <% recentOrders.forEach(order => { %>
                                <tr class="border-b border-white/5 last:border-0 hover:bg-white/[0.02]">
                                    <td class="p-4 font-mono text-xs text-gray-400">#<%= order._id.toString().slice(-6) %></td>
                                    <td class="p-4 text-gray-300"><%= new Date(order.createdAt).toLocaleString() %></td>
                                    <td class="p-4 font-bold text-white"><%= order.tableNumber %></td>
                                    <td class="p-4 text-emerald-400 font-bold">₹<%= order.totalAmount %></td>
                                    <td class="p-4">
                                        <% if(order.rating) { %>
                                            <span class="text-yellow-400"><%= '⭐'.repeat(order.rating) %></span>
                                            <% if(order.comment) { %>
                                                <p class="text-xs text-gray-400 italic mt-1">"<%= order.comment %>"</p>
                                            <% } %>
                                        <% } else { %>
                                            <span class="text-gray-600 text-xs">No rating</span>
                                        <% } %>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </main>
</body>
</html>