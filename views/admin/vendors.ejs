<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Manage Vendors - inOrder</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #07090F; color: #ffffff; }
        .bg-gradient-primary { background-image: linear-gradient(to right, #8b5cf6, #3b82f6); }
    </style>
</head>
<body class="antialiased">

    <!-- Admin Navbar -->
    <nav class="bg-[#0B0E16] border-b border-white/[0.05] sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center">
            <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-lg bg-gradient-primary flex items-center justify-center shadow-[0_0_15px_rgba(139,92,246,0.4)]">
                    <span class="font-bold text-white text-sm">A</span>
                </div>
                <span class="text-xl font-bold tracking-tight">inOrder Admin</span>
            </div>
            <div class="flex items-center gap-6">
                <a href="/admin/dashboard" class="text-gray-400 hover:text-white transition">Overview</a>
                <a href="/admin/vendors" class="text-blue-400 font-medium">Vendors</a>
                <a href="/logout" class="bg-white/10 hover:bg-white/20 px-4 py-2 rounded-lg text-sm font-medium transition">Logout</a>
            </div>
        </div>
    </nav>

    <!-- Content -->
    <main class="max-w-7xl mx-auto px-6 py-8">
        <h1 class="text-3xl font-bold mb-8">Vendor Management</h1>

        <div class="bg-[#121624] border border-white/5 rounded-2xl p-6 shadow-lg">
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                <% vendors.forEach(v => { %>
    <div class="bg-[#0B0E16] border border-white/5 rounded-xl p-5 relative">
        <h3 class="font-bold text-lg text-white"><%= v.shopName %></h3>
        <p class="text-sm text-gray-400 mt-1">👤 <%= v.name %> | 📞 <%= v.phone %></p>
        
        <!-- Show KYC Docs to Admin -->
        <div class="mt-3 flex gap-2">
            <% if(v.aadharImage) { %>
                <a href="<%= v.aadharImage %>" target="_blank" class="bg-white/10 hover:bg-white/20 text-[10px] px-2 py-1 rounded text-white transition">📄 View Aadhar</a>
            <% } else { %>
                <span class="bg-red-500/10 text-red-500 text-[10px] px-2 py-1 rounded">No Aadhar</span>
            <% } %>

            <% if(v.panImage) { %>
                <a href="<%= v.panImage %>" target="_blank" class="bg-white/10 hover:bg-white/20 text-[10px] px-2 py-1 rounded text-white transition">📄 View PAN</a>
            <% } else { %>
                <span class="bg-red-500/10 text-red-500 text-[10px] px-2 py-1 rounded">No PAN</span>
            <% } %>
        </div>
        
        <div class="mt-4 pt-4 border-t border-white/10 flex justify-between items-center">
            <% if(v.isApproved) { %>
                <span class="text-emerald-400 font-bold text-sm">✅ Active</span>
                <form action="/admin/vendor/suspend/<%= v._id %>" method="POST">
                    <button type="submit" class="bg-red-500/20 text-red-400 hover:bg-red-500/40 px-3 py-1.5 rounded text-xs font-bold transition">Suspend</button>
                </form>
            <% } else { %>
                <span class="text-yellow-400 font-bold text-sm">⏳ Pending</span>
                <form action="/admin/vendor/approve/<%= v._id %>" method="POST">
                    <button type="submit" class="bg-emerald-500/20 text-emerald-400 hover:bg-emerald-500/40 px-3 py-1.5 rounded text-xs font-bold transition">Approve Vendor</button>
                </form>
            <% } %>
        </div>
    </div>
<% }) %>
            </div>
        </div>
    </main>
</body>
</html>