<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - inOrder</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #07090F; color: #ffffff; }
        .bg-gradient-primary { background-image: linear-gradient(to right, #FF6B00, #FF3D3D); }
    </style>
</head>
<body class="antialiased flex items-center justify-center min-h-screen relative overflow-hidden selection:bg-orange-500/30">
    
    <!-- Ambient Background Glows -->
    <div class="absolute top-[-10%] left-[-10%] w-[50vw] h-[50vw] rounded-full bg-orange-600/10 blur-[120px] pointer-events-none z-[-1]"></div>
    <div class="absolute bottom-[-10%] right-[-10%] w-[50vw] h-[50vw] rounded-full bg-red-600/10 blur-[120px] pointer-events-none z-[-1]"></div>

    <div class="w-full max-w-md px-6 z-10">
        <!-- Header -->
        <div class="text-center mb-8">
            <div class="inline-flex items-center justify-center w-12 h-12 rounded-xl bg-gradient-primary shadow-[0_0_20px_rgba(255,107,0,0.4)] mb-4">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
            </div>
            <h1 class="text-3xl font-bold tracking-tight">Welcome Back</h1>
            <p class="text-gray-400 mt-2 text-sm font-light">Sign in to manage your orders & queue</p>
        </div>

        <!-- Login Card -->
        <div class="bg-[#121624] border border-white/5 rounded-3xl p-8 shadow-2xl relative overflow-hidden">
            <div class="absolute inset-0 bg-gradient-to-br from-orange-500/5 to-transparent pointer-events-none"></div>
            
            <% if (error) { %>
                <div class="bg-red-500/10 border border-red-500/20 text-red-400 text-sm p-3 rounded-xl mb-6 text-center backdrop-blur-sm">
                    <%= error %>
                </div>
            <% } %>

            <form action="/login" method="POST" class="space-y-5 relative z-10">
                <div>
                    <label class="block text-sm font-medium text-gray-300 mb-1.5">Phone Number</label>
                    <input type="tel" name="phone" required class="w-full bg-[#0B0E16] border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-orange-500 focus:ring-1 focus:ring-orange-500 transition-colors" placeholder="e.g. 9876543210">
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-300 mb-1.5">Password</label>
                    <input type="password" name="password" required class="w-full bg-[#0B0E16] border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-orange-500 focus:ring-1 focus:ring-orange-500 transition-colors" placeholder="••••••••">
                </div>
                
                <button type="submit" class="w-full bg-gradient-primary text-white font-bold rounded-xl px-4 py-3.5 mt-2 shadow-[0_4px_15px_rgba(255,107,0,0.3)] hover:shadow-[0_6px_25px_rgba(255,107,0,0.5)] transition-all transform hover:-translate-y-0.5">
                    Sign In
                </button>
            </form>
            
            <p class="text-center text-sm text-gray-400 mt-6 relative z-10">
                Don't have an account? <a href="/register" class="text-orange-500 hover:text-orange-400 font-medium transition-colors">Register here</a>
            </p>
        </div>
    </div>
</body>
</html>